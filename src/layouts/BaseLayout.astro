---
import "../styles/global.css";
import { getCollection } from "astro:content";
import Header from "../components/layout/Header.astro";
import Sidebar from "../components/layout/Sidebar.astro";
import LayoutScripts from "../components/layout/LayoutScripts.astro";
import { normalizeCategory } from "../utils/categories";
import { buildTagSummary } from "../utils/tags";
import { buildSidebarNavigation } from "../utils/navigation";
import {
  SIDEBAR_TAG_LIMIT,
  SITE_AUTHOR,
  SITE_DESCRIPTION,
  SITE_OG_IMAGE,
  SITE_TITLE,
  SITE_URL
} from "../utils/posts";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  minimalHome?: boolean;
  wideContent?: boolean;
  publishedTime?: string;
  updatedTime?: string;
  type?: "website" | "article";
  structuredData?: unknown;
  currentCategory?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image = SITE_OG_IMAGE,
  minimalHome = false,
  wideContent = false,
  publishedTime,
  updatedTime,
  type = "website",
  structuredData,
  currentCategory: currentCategoryName
} = Astro.props;

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sidebarNavigation = buildSidebarNavigation(posts);
const tagSummary = buildTagSummary(posts).slice(0, SIDEBAR_TAG_LIMIT);
const siteUrl = Astro.site ?? new URL(SITE_URL);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(image, siteUrl).toString();

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const routeCategory = currentPath.startsWith("/categories/") ? currentPath.split("/")[2] ?? "" : "";
const currentCategory = currentCategoryName?.trim()
  ? normalizeCategory(currentCategoryName)
  : routeCategory;
const currentTag = currentPath.startsWith("/tags/") ? currentPath.split("/")[2] ?? "" : "";

function serializeJsonLd(value: unknown) {
  return JSON.stringify(value).replace(/</g, "\\u003c");
}
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={SITE_AUTHOR} />
    <meta name="color-scheme" content="light dark" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_TITLE} RSS`} href={new URL("/rss.xml", siteUrl).toString()} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={`${SITE_TITLE} 대표 이미지`} />
    {type === "article" && <meta property="article:author" content={SITE_AUTHOR} />}
    {type === "article" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {type === "article" && updatedTime && <meta property="article:modified_time" content={updatedTime} />}
    {structuredData && <script is:inline type="application/ld+json" set:html={serializeJsonLd(structuredData)} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={`${SITE_TITLE} 대표 이미지`} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        let stored = null;

        try {
          stored = localStorage.getItem("theme");
        } catch {
        }

        const theme = stored === "light" || stored === "dark" ? stored : systemDark ? "dark" : "light";
        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
    <script is:inline>
      (() => {
        try {
          const desktop = window.matchMedia("(min-width: 981px)").matches;
          const collapsed = localStorage.getItem("blog-left-sidebar-collapsed") === "true";

          if (desktop && collapsed) {
            document.documentElement.classList.add("left-sidebar-collapsed");
          }
        } catch {
          document.documentElement.classList.remove("left-sidebar-collapsed");
        }
      })();
    </script>
  </head>
  <body class:list={[minimalHome && "page-home-simple"]}>
    <div class:list={["site-shell", wideContent && "site-shell--wide"]}>
      <Header currentPath={currentPath} />

      <div class:list={["site-layout", minimalHome && "site-layout--minimal", wideContent && "site-layout--wide"]}>
        {
          !minimalHome && (
            <Sidebar
              categoryHierarchy={sidebarNavigation}
              tagSummary={tagSummary}
              totalPostCount={posts.length}
              currentCategory={currentCategory}
              currentTag={currentTag}
              currentPath={currentPath}
            />
          )
        }

        <div class="site-content">
          <main class="site-main">
            <slot />
          </main>
        </div>
      </div>

    </div>

    <LayoutScripts />
  </body>
</html>
