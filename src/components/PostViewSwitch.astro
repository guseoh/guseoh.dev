---
interface Props {
  listId: string;
  storageKey: string;
  ariaLabel?: string;
  defaultView?: "grid" | "list";
}

const {
  listId,
  storageKey,
  ariaLabel = "Toggle post list view",
  defaultView = "grid"
} = Astro.props as Props;
---

<div
  class="view-switch"
  role="group"
  aria-label={ariaLabel}
  data-view-switch
  data-view-list-id={listId}
  data-view-storage-key={storageKey}
  data-view-default={defaultView}
>
  <button type="button" class="view-switch__button" data-view-button="grid" aria-label="Grid view">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <rect x="4" y="4" width="6" height="6"></rect>
      <rect x="14" y="4" width="6" height="6"></rect>
      <rect x="4" y="14" width="6" height="6"></rect>
      <rect x="14" y="14" width="6" height="6"></rect>
    </svg>
  </button>
  <button type="button" class="view-switch__button" data-view-button="list" aria-label="List view">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M5 7h14M5 12h14M5 17h14"></path>
    </svg>
  </button>
</div>

<script is:inline>
  (() => {
    const setupViewSwitches = () => {
      const switches = document.querySelectorAll("[data-view-switch]:not([data-view-switch-ready])");

      for (const switcher of switches) {
        if (!(switcher instanceof HTMLElement)) continue;

        const listId = switcher.dataset.viewListId;
        const storageKey = switcher.dataset.viewStorageKey;
        const defaultView = switcher.dataset.viewDefault === "list" ? "list" : "grid";
        const list = listId ? document.getElementById(listId) : null;
        const buttons = Array.from(switcher.querySelectorAll("[data-view-button]"));

        if (!(list instanceof HTMLElement) || !storageKey || buttons.length === 0) continue;
        switcher.setAttribute("data-view-switch-ready", "true");

        const getStoredView = () => {
          try {
            const stored = localStorage.getItem(storageKey);
            return stored === "grid" || stored === "list" ? stored : defaultView;
          } catch {
            return defaultView;
          }
        };

        const setStoredView = (mode) => {
          try {
            localStorage.setItem(storageKey, mode);
          } catch {
            // The active button still reflects the selected view when storage is unavailable.
          }
        };

        const apply = (mode) => {
          const nextMode = mode === "list" ? "list" : "grid";
          list.dataset.view = nextMode;

          for (const button of buttons) {
            if (!(button instanceof HTMLButtonElement)) continue;
            const isActive = button.dataset.viewButton === nextMode;
            button.classList.toggle("is-active", isActive);
            button.setAttribute("aria-pressed", isActive ? "true" : "false");
          }
        };

        apply(getStoredView());

        for (const button of buttons) {
          if (!(button instanceof HTMLButtonElement)) continue;
          button.addEventListener("click", () => {
            const mode = button.dataset.viewButton === "list" ? "list" : "grid";
            setStoredView(mode);
            apply(mode);
          });
        }
      }
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupViewSwitches, { once: true });
      return;
    }

    setupViewSwitches();
  })();
</script>
