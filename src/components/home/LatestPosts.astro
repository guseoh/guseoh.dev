---
import type { CollectionEntry } from "astro:content";
import PostCard from "../PostCard.astro";
import PostViewSwitch from "../PostViewSwitch.astro";
import { HOME_POST_LIMIT } from "../../utils/posts";

interface Props {
  posts: CollectionEntry<"blog">[];
  limit?: number;
}

const { posts, limit = HOME_POST_LIMIT } = Astro.props as Props;
const visiblePosts = posts.slice(0, limit);
---

<section class="home-section home-latest-posts" aria-label="Recent posts">
  <div class="home-section__head home-section__head--inline">
    <h2 class="home-section__title">최근 글</h2>
    <div class="home-section__actions">
      <a class="home-section__link" href="/blog/">전체 글</a>
      <PostViewSwitch
        listId="home-latest-post-list"
        storageKey="guseo:home-list-view"
        ariaLabel="Toggle recent posts view"
      />
    </div>
  </div>

  {visiblePosts.length === 0 ? (
    <p class="section-empty">아직 공개된 글이 없습니다.</p>
  ) : (
    <ul id="home-latest-post-list" class="post-list post-list--switch home-post-list" data-post-list>
      {visiblePosts.map((post) => (
        <li>
          <PostCard post={post} variant="latest" />
        </li>
      ))}
    </ul>
  )}
</section>

