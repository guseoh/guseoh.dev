---
import type { HomeTopicView } from "../../utils/navigation";

interface Props {
  groups: HomeTopicView[];
}

const { groups } = Astro.props as Props;
---

<section class="home-section home-topic-index" aria-labelledby="home-topic-index-title">
  <div class="home-section__head home-section__head--inline">
    <div>
      <p class="home-section__eyebrow">Topic Index</p>
      <h2 id="home-topic-index-title" class="home-section__title">학습과 프로젝트 탐색</h2>
    </div>
    <a class="home-section__link" href="/categories/">전체 카테고리</a>
  </div>

  {groups.length === 0 ? (
    <p class="section-empty">카테고리가 없습니다.</p>
  ) : (
    <div class="topic-index-grid">
      {groups.map((group) => (
        <a class="topic-index-group" href={group.href}>
          <span class="topic-index-group__head">
            <strong>{group.title}</strong>
            <span class="topic-index-group__count">{group.count}개 글</span>
          </span>
          <span class="topic-index-group__description">{group.description}</span>
        </a>
      ))}
    </div>
  )}
</section>

