---
import { CORE_TECH_TAGS, GITHUB_URL, SITE_DESCRIPTION, SITE_TITLE } from "../../utils/posts";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION
} = Astro.props as Props;
---

<section class="archive-hero archive-hero--simple" aria-label="Blog intro">
  <p class="archive-hero__eyebrow">{title}</p>
  <h1>Java/Spring 백엔드 개발자 오지훈입니다.</h1>
  <p class="archive-hero__lead">
    Board 프로젝트를 중심으로 Spring Boot, JPA, QueryDSL, Docker, CI/CD, 모니터링,
    성능 개선 과정을 기록합니다.
  </p>
  <p class="archive-hero__subtitle">{description}</p>

  <div class="hero-tech-tags" aria-label="주요 관심 기술">
    {CORE_TECH_TAGS.map((tag) => <span class="hero-tech-tag">{tag}</span>)}
  </div>

  <div class="archive-hero__actions">
    <a class="archive-hero__button" href="/about/">About</a>
    <a class="archive-hero__button archive-hero__button--ghost" href={GITHUB_URL} target="_blank" rel="noreferrer">
      GitHub
    </a>
  </div>
</section>
