---
import { SITE_TITLE } from "../../utils/posts";

interface Props {
  title?: string;
}

const { title = SITE_TITLE } = Astro.props as Props;
---

<section class="archive-hero archive-hero--simple" aria-label="Blog intro">
  <p class="archive-hero__eyebrow">{title}</p>
  <h1>Java/Spring 백엔드 개발자 오지훈입니다.</h1>
</section>

