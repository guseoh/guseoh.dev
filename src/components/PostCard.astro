---
import type { CollectionEntry } from "astro:content";
import PostMetaBadges from "./PostMetaBadges.astro";
import { formatPostDate, getPostDescription, getPostPath, getPostSlug, getReadingTime } from "../utils/posts";

interface Props {
  post: CollectionEntry<"blog">;
  variant?: "default" | "latest";
}

const { post, variant = "default" } = Astro.props as Props;
const isLatest = variant === "latest";
const readingTime = getReadingTime(post);
const description = getPostDescription(post);
const postPath = getPostPath(post);
const postSlug = getPostSlug(post);
---

<article class:list={["card", "post-card", isLatest && "post-card--latest"]} data-post-slug={postSlug}>
  <header class="post-card__header">
    <h2><a href={postPath}>{post.data.title}</a></h2>
  </header>

  <p class="post-card__description">{description}</p>

  <div class="post-card__footer">
    <div class="post-card__meta">
      <span>작성</span>
      <time datetime={post.data.date.toISOString()}>{formatPostDate(post.data.date)}</time>
      <span aria-hidden="true">·</span>
      <span>{readingTime}</span>
    </div>

    <PostMetaBadges category={post.data.category} tags={post.data.tags} maxTags={isLatest ? 3 : 4} />
  </div>
</article>

