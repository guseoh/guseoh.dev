---
import {
  siDocker,
  siFlyway,
  siGit,
  siGrafana,
  siHibernate,
  siOpenjdk,
  siPostgresql,
  siPrometheus,
  siReact,
  siSpring,
  siSpringsecurity,
  type SimpleIcon
} from "simple-icons";
import { normalizeCategory } from "../utils/categories";

interface Props {
  category: string;
}

type FallbackIconDefinition = {
  paths: readonly string[];
};

// Brand SVG data is imported from Simple Icons instead of being copied into
// the repository. Keep aliases here so category and tag spellings resolve in
// one place. JPA intentionally uses Hibernate because JPA has no distinct,
// broadly recognized official brand icon.
const brandIcons = {
  docker: siDocker,
  flyway: siFlyway,
  git: siGit,
  grafana: siGrafana,
  hibernate: siHibernate,
  java: siOpenjdk,
  postgresql: siPostgresql,
  prometheus: siPrometheus,
  react: siReact,
  spring: siSpring,
  "spring-security": siSpringsecurity
} satisfies Record<string, SimpleIcon>;

// These generic categories are project-authored line icons, not brand marks.
const fallbackIcons = {
  board: {
    paths: ["M4 5h16v14H4z", "M8 5v14", "M8 10h12"]
  },
  database: {
    paths: [
      "M4 5c0 1.1 3.6 2 8 2s8-.9 8-2-3.6-2-8-2-8 .9-8 2z",
      "M4 5v14c0 1.1 3.6 2 8 2s8-.9 8-2V5",
      "M4 12c0 1.1 3.6 2 8 2s8-.9 8-2"
    ]
  },
  network: {
    paths: [
      "M12 5a2 2 0 1 0 0-4 2 2 0 0 0 0 4z",
      "M5 22a2 2 0 1 0 0-4 2 2 0 0 0 0 4z",
      "M19 22a2 2 0 1 0 0-4 2 2 0 0 0 0 4z",
      "M12 5v5M5 18v-3h14v3"
    ]
  },
  os: {
    paths: ["M3 4h18v13H3z", "M8 21h8", "M12 17v4"]
  },
  repository: {
    paths: ["M5 4h12a2 2 0 0 1 2 2v14H7a2 2 0 0 1-2-2V4z", "M9 4v16", "M13 8h3"]
  }
} satisfies Record<string, FallbackIconDefinition>;

const iconAliases: Record<string, string> = {
  db: "database",
  github: "repository",
  "github-actions": "repository",
  jpa: "hibernate",
  mysql: "database",
  openjdk: "java",
  springsecurity: "spring-security"
};

const { category } = Astro.props as Props;
const normalizedCategory = normalizeCategory(category);
const iconKey = iconAliases[normalizedCategory] ?? normalizedCategory;
const brandIcon = brandIcons[iconKey as keyof typeof brandIcons];
const fallbackIcon = fallbackIcons[iconKey as keyof typeof fallbackIcons];
const iconPaths = brandIcon ? [brandIcon.path] : fallbackIcon?.paths;
---

{
  iconPaths && (
    <svg
      class="category-icon"
      viewBox="0 0 24 24"
      aria-hidden="true"
      focusable="false"
      data-icon-source={brandIcon ? "simple-icons" : "project"}
      data-simple-icons-slug={brandIcon?.slug}
      fill={brandIcon ? "currentColor" : "none"}
      stroke={fallbackIcon ? "currentColor" : "none"}
      stroke-width={fallbackIcon ? "1.8" : undefined}
      stroke-linecap={fallbackIcon ? "round" : undefined}
      stroke-linejoin={fallbackIcon ? "round" : undefined}
    >
      {iconPaths.map((path) => <path d={path}></path>)}
    </svg>
  )
}
