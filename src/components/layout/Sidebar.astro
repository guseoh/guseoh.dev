---
import CategoryMenu from "../CategoryMenu.astro";
import type { CategoryTreeGroup } from "../../utils/categories";
import type { TagSummary } from "../../utils/tags";

interface Props {
  categoryHierarchy: CategoryTreeGroup[];
  tagSummary: TagSummary[];
  totalPostCount: number;
  currentCategory: string;
  currentTag: string;
  currentPath: string;
}

const { categoryHierarchy, tagSummary, totalPostCount, currentCategory, currentTag, currentPath } = Astro.props as Props;
const normalizedCurrentPath = currentPath.replace(/\/+$/, "") || "/";
const isCategoriesPage = normalizedCurrentPath === "/categories";
---

<button id="sidebar-open" class="sidebar-open" type="button" aria-label="사이드바 열기" aria-controls="site-sidebar" aria-expanded="false">
  <span class="sidebar-open__line"></span>
  <span class="sidebar-open__line"></span>
  <span class="sidebar-open__line"></span>
</button>

<button id="sidebar-backdrop" class="sidebar-backdrop" type="button" aria-label="사이드바 닫기" hidden></button>

<aside id="site-sidebar" class="site-sidebar" aria-label="사이트 탐색" aria-hidden="false" tabindex="-1">
  <section class="sidebar-close-section" aria-label="사이드바 제어">
    <button id="sidebar-collapse-toggle" class="sidebar-collapse-toggle" type="button" aria-label="사이드바 닫기" aria-controls="site-sidebar" aria-expanded="true">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M6 6l12 12M18 6 6 18"></path>
      </svg>
      <span>사이드바 닫기</span>
    </button>

    <button id="sidebar-close" class="sidebar-close" type="button" aria-label="사이드바 닫기" aria-controls="site-sidebar" aria-expanded="true">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M6 6l12 12M18 6 6 18"></path>
      </svg>
    </button>
  </section>

  <form class="sidebar-search" action="/search/" method="get" aria-label="게시글 검색">
    <label class="sr-only" for="sidebar-search-input">게시글 검색</label>
    <input id="sidebar-search-input" name="q" type="search" placeholder="Search posts" />
    <button type="submit" aria-label="검색 실행">Search</button>
  </form>

  <section class="category-panel" aria-label="분류 탐색">
    <div class="category-panel__header">
      <h2>전체 탐색</h2>
      <a
        href="/categories/"
        aria-current={isCategoriesPage ? "page" : undefined}
        data-sidebar-current={isCategoriesPage ? "page" : undefined}
      >Categories</a>
    </div>

    {
      categoryHierarchy.length === 0 ? (
        <p class="category-empty">No categories yet.</p>
      ) : (
        <CategoryMenu
          groups={categoryHierarchy}
          idPrefix="sidebar-category"
          variant="sidebar"
          totalCount={totalPostCount}
          currentPath={currentPath}
          currentCategory={currentCategory}
          showAllLink={true}
          label="카테고리 탐색"
        />
      )
    }

    {
      tagSummary.length > 0 && (
        <>
          <p class="category-panel__subhead">Tags</p>
          <nav class="topic-cloud topic-cloud--tags" aria-label="태그 탐색">
            {tagSummary.map(({ tag, name, count }) => {
              const isActive = currentTag === tag;

              return (
                <a
                  class:list={["topic-pill", "topic-pill--tag", isActive && "is-active"]}
                  href={`/tags/${tag}/`}
                  aria-current={isActive ? "page" : undefined}
                  data-sidebar-current={isActive ? "tag" : undefined}
                >
                  <span>#{name}</span>
                  <strong>{count}</strong>
                </a>
              );
            })}
          </nav>
        </>
      )
    }
  </section>
</aside>
