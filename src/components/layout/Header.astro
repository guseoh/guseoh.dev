---
import ThemeToggle from "./ThemeToggle.astro";
import { GITHUB_URL } from "../../utils/posts";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props as Props;

const headerLinks = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Posts" },
  { href: "/books", label: "Books" },
  { href: "/series", label: "Series" },
  { href: "/search", label: "Search" }
];

function isNavActive(href: string) {
  const normalizedHref = href === "/" ? "/" : href.replace(/\/+$/, "");
  if (normalizedHref === "/") return currentPath === "/";

  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
}
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="/" aria-label="devjune.dev 홈으로 이동">devjune.dev</a>

    <div class="header-actions">
      <button
        id="header-menu-toggle"
        class="header-menu-toggle"
        type="button"
        aria-label="메인 메뉴 열기"
        aria-controls="top-nav"
        aria-expanded="false"
      >
        <span class="header-menu-toggle__line"></span>
        <span class="header-menu-toggle__line"></span>
        <span class="header-menu-toggle__line"></span>
      </button>

      <nav id="top-nav" class="top-nav" aria-label="Primary navigation">
        {
          headerLinks.map(({ href, label }) => (
            <a
              class:list={["top-nav__link", isNavActive(href) && "is-active"]}
              href={href}
              aria-current={isNavActive(href) ? "page" : undefined}
            >
              {label}
            </a>
          ))
        }
        <a class="top-nav__link top-nav__link--external" href={GITHUB_URL} target="_blank" rel="noreferrer">
          GitHub
        </a>
      </nav>

      <ThemeToggle />
    </div>
  </div>
</header>
