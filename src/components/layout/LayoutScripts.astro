<script is:inline>
  (() => {
    const root = document.documentElement;
    const themeButton = document.getElementById("theme-toggle");
    const themeMedia = window.matchMedia("(prefers-color-scheme: dark)");
    const label = themeButton?.querySelector(".theme-toggle__label");

    const themeModes = ["system", "light", "dark"];
    const getStoredThemeMode = () => {
      try {
        const stored = localStorage.getItem("theme");
        return themeModes.includes(stored) ? stored : "system";
      } catch {
        return "system";
      }
    };

    const getEffectiveTheme = (mode) => {
      if (mode === "light" || mode === "dark") return mode;
      return themeMedia.matches ? "dark" : "light";
    };

    const getThemeModeLabel = (mode) => {
      if (mode === "light") return "Light";
      if (mode === "dark") return "Dark";
      return "System";
    };

    const updateThemeButton = (mode, theme) => {
      if (themeButton instanceof HTMLButtonElement) {
        const current = getThemeModeLabel(mode);
        const effective = mode === "system" ? ` (${theme === "dark" ? "Dark" : "Light"})` : "";
        themeButton.dataset.theme = theme;
        themeButton.dataset.themeMode = mode;
        themeButton.removeAttribute("aria-pressed");
        themeButton.setAttribute("aria-label", `현재 테마: ${current}${effective}. 테마를 전환합니다.`);
        themeButton.title = `현재 테마: ${current}${effective}`;

        if (label instanceof HTMLElement) {
          label.textContent = current;
        }
      }
    };

    const applyThemeMode = (mode, { persist = true, notify = true } = {}) => {
      const nextMode = themeModes.includes(mode) ? mode : "system";
      const nextTheme = getEffectiveTheme(nextMode);
      root.setAttribute("data-theme", nextTheme);
      root.setAttribute("data-theme-mode", nextMode);
      root.style.colorScheme = nextTheme;
      updateThemeButton(nextMode, nextTheme);

      if (persist) {
        try {
          localStorage.setItem("theme", nextMode);
        } catch {
        }
      }

      if (notify) {
        window.dispatchEvent(new CustomEvent("themechange", { detail: { theme: nextTheme, mode: nextMode } }));
      }
    };

    const currentMode = root.getAttribute("data-theme-mode") || getStoredThemeMode();
    applyThemeMode(currentMode, { persist: false, notify: false });

    if (themeButton instanceof HTMLButtonElement) {
      themeButton.addEventListener("click", () => {
        const mode = root.getAttribute("data-theme-mode") || "system";
        const index = themeModes.indexOf(mode);
        applyThemeMode(themeModes[(index + 1) % themeModes.length]);
      });
    }

    window.addEventListener("storage", (event) => {
      if (event.key === "theme") {
        applyThemeMode(themeModes.includes(event.newValue) ? event.newValue : "system", { persist: false });
      }
    });

    themeMedia.addEventListener("change", () => {
      const mode = root.getAttribute("data-theme-mode") || getStoredThemeMode();
      if (mode === "system") {
        applyThemeMode("system", { persist: false });
      }
    });

    window.addEventListener("keydown", (event) => {
      if (!(event.key.toLowerCase() === "k" && (event.ctrlKey || event.metaKey)) || event.altKey) {
        return;
      }

      const activeElement = document.activeElement;
      const isEditable = activeElement instanceof HTMLInputElement
        || activeElement instanceof HTMLTextAreaElement
        || activeElement instanceof HTMLSelectElement
        || activeElement?.getAttribute("contenteditable") === "true";

      if (isEditable) return;

      event.preventDefault();
      const searchInput = document.getElementById("search-page-input");

      if (searchInput instanceof HTMLInputElement) {
        searchInput.focus();
        searchInput.select();
        return;
      }

      window.location.href = "/search/?focus=1";
    });

    const headerMenuButton = document.getElementById("header-menu-toggle");
    const headerNav = document.getElementById("top-nav");

    if (headerMenuButton instanceof HTMLButtonElement && headerNav instanceof HTMLElement) {
      const headerMedia = window.matchMedia("(max-width: 760px)");

      const applyHeaderMenuState = (open, { restoreFocus = false } = {}) => {
        const narrow = headerMedia.matches;
        const shouldOpen = narrow && Boolean(open);

        headerNav.classList.toggle("is-open", shouldOpen);
        headerNav.inert = narrow && !shouldOpen;
        headerMenuButton.setAttribute("aria-expanded", shouldOpen ? "true" : "false");
        headerMenuButton.setAttribute("aria-label", shouldOpen ? "메인 메뉴 닫기" : "메인 메뉴 열기");

        if (narrow && !shouldOpen) {
          headerNav.setAttribute("aria-hidden", "true");
        } else {
          headerNav.removeAttribute("aria-hidden");
        }

        if (restoreFocus) {
          headerMenuButton.focus();
        }
      };

      applyHeaderMenuState(false);

      headerMenuButton.addEventListener("click", () => {
        const open = headerMenuButton.getAttribute("aria-expanded") === "true";
        applyHeaderMenuState(!open);
      });

      headerNav.addEventListener("click", (event) => {
        if (event.target instanceof HTMLAnchorElement && headerMedia.matches) {
          applyHeaderMenuState(false);
        }
      });

      document.addEventListener("click", (event) => {
        if (
          headerMedia.matches &&
          headerMenuButton.getAttribute("aria-expanded") === "true" &&
          event.target instanceof Node &&
          !headerMenuButton.contains(event.target) &&
          !headerNav.contains(event.target)
        ) {
          applyHeaderMenuState(false);
        }
      });

      window.addEventListener("keydown", (event) => {
        if (
          event.key === "Escape" &&
          headerMedia.matches &&
          headerMenuButton.getAttribute("aria-expanded") === "true"
        ) {
          event.preventDefault();
          applyHeaderMenuState(false, { restoreFocus: true });
        }
      });

      headerMedia.addEventListener("change", () => applyHeaderMenuState(false));
    }

    const shell = document.querySelector(".site-shell");
    const sidebar = document.getElementById("site-sidebar");
    const sidebarOpenButton = document.getElementById("sidebar-open");
    const sidebarCollapseButton = document.getElementById("sidebar-collapse-toggle");
    const sidebarCloseButton = document.getElementById("sidebar-close");
    const sidebarBackdrop = document.getElementById("sidebar-backdrop");

    if (
      shell instanceof HTMLElement &&
      sidebar instanceof HTMLElement &&
      sidebarOpenButton instanceof HTMLButtonElement &&
      sidebarCollapseButton instanceof HTMLButtonElement &&
      sidebarCloseButton instanceof HTMLButtonElement
    ) {
      const storageKey = "blog-left-sidebar-collapsed";
      const media = window.matchMedia("(max-width: 980px)");
      const motionMedia = window.matchMedia("(prefers-reduced-motion: reduce)");
      const isNarrow = () => media.matches;
      const prefersReducedMotion = () => motionMedia.matches;
      const backgroundElements = [
        document.querySelector(".site-header"),
        document.querySelector(".site-content")
      ].filter((element) => element instanceof HTMLElement);
      let sidebarTrigger = sidebarOpenButton;
      let backdropHideTimer = 0;

      const revealWithin = (container, element) => {
        const containerRect = container.getBoundingClientRect();
        const elementRect = element.getBoundingClientRect();

        if (elementRect.top < containerRect.top) {
          container.scrollTop -= containerRect.top - elementRect.top;
        } else if (elementRect.bottom > containerRect.bottom) {
          container.scrollTop += elementRect.bottom - containerRect.bottom;
        }
      };

      const revealCurrentSidebarItem = () => {
        const currentItem = sidebar.querySelector('[data-sidebar-current="tag"]')
          ?? sidebar.querySelector('[data-sidebar-current="category"]')
          ?? sidebar.querySelector("[data-sidebar-current]");
        if (!(currentItem instanceof HTMLElement)) return;

        const nestedScroller = currentItem.closest(".topic-cloud");
        if (nestedScroller instanceof HTMLElement) {
          revealWithin(nestedScroller, currentItem);
        }

        revealWithin(sidebar, currentItem);
      };

      const getFocusableElements = () =>
        Array.from(
          sidebar.querySelectorAll(
            'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
          )
        ).filter((element) =>
          element instanceof HTMLElement &&
          !element.hidden &&
          element.getAttribute("aria-hidden") !== "true" &&
          element.getClientRects().length > 0
        );

      const setBackgroundInert = (inert) => {
        for (const element of backgroundElements) {
          element.inert = inert;
        }
      };

      const getStoredCollapsed = () => {
        try {
          return localStorage.getItem(storageKey) === "true";
        } catch {
          return false;
        }
      };

      const setStoredCollapsed = (collapsed) => {
        try {
          localStorage.setItem(storageKey, collapsed ? "true" : "false");
        } catch {
        }
      };

      const setBackdropVisible = (visible) => {
        if (!(sidebarBackdrop instanceof HTMLButtonElement)) return;

        window.clearTimeout(backdropHideTimer);

        if (visible) {
          sidebarBackdrop.hidden = false;
          sidebarBackdrop.getBoundingClientRect();
          sidebarBackdrop.classList.add("is-visible");
          return;
        }

        sidebarBackdrop.classList.remove("is-visible");

        if (prefersReducedMotion() || sidebarBackdrop.hidden) {
          sidebarBackdrop.hidden = true;
          return;
        }

        const hide = () => {
          sidebarBackdrop.hidden = true;
        };

        sidebarBackdrop.addEventListener("transitionend", hide, { once: true });
        backdropHideTimer = window.setTimeout(hide, 260);
      };

      const applySidebarState = (
        collapsed,
        persist = false,
        { moveFocus = false, restoreFocus = false } = {}
      ) => {
        const narrow = isNarrow();
        const shouldCollapse = Boolean(collapsed);
        const modalOpen = narrow && !shouldCollapse;
        const openLabel = "사이드바 열기";

        shell.classList.toggle("sidebar-collapsed", shouldCollapse);
        document.documentElement.classList.toggle("left-sidebar-collapsed", !narrow && shouldCollapse);
        document.body.classList.toggle("has-sidebar-open", modalOpen);
        sidebar.setAttribute("aria-hidden", shouldCollapse ? "true" : "false");
        sidebar.inert = narrow && shouldCollapse;

        if (modalOpen) {
          sidebar.setAttribute("role", "dialog");
          sidebar.setAttribute("aria-modal", "true");
        } else {
          sidebar.removeAttribute("role");
          sidebar.removeAttribute("aria-modal");
        }

        sidebarOpenButton.hidden = !shouldCollapse;
        sidebarOpenButton.setAttribute("aria-label", openLabel);
        sidebarOpenButton.setAttribute("aria-expanded", shouldCollapse ? "false" : "true");
        sidebarOpenButton.title = openLabel;
        sidebarCollapseButton.hidden = narrow || shouldCollapse;
        sidebarCollapseButton.setAttribute("aria-expanded", shouldCollapse ? "false" : "true");
        sidebarCollapseButton.setAttribute("aria-label", "사이드바 닫기");
        sidebarCloseButton.hidden = !narrow;
        sidebarCloseButton.setAttribute("aria-expanded", shouldCollapse ? "false" : "true");

        setBackdropVisible(modalOpen);

        setBackgroundInert(modalOpen);

        if (!narrow && persist) {
          setStoredCollapsed(shouldCollapse);
        }

        if (!shouldCollapse) {
          window.requestAnimationFrame(revealCurrentSidebarItem);
        }

        if (moveFocus && modalOpen) {
          window.requestAnimationFrame(() => {
            const firstFocusable = getFocusableElements()[0];
            if (firstFocusable instanceof HTMLElement) {
              firstFocusable.focus();
            } else {
              sidebar.focus();
            }
          });
        } else if (restoreFocus && sidebarTrigger instanceof HTMLElement) {
          sidebarTrigger.focus();
        }
      };

      applySidebarState(isNarrow() ? true : getStoredCollapsed());

      sidebarOpenButton.addEventListener("click", () => {
        sidebarTrigger = document.activeElement instanceof HTMLElement
          ? document.activeElement
          : sidebarOpenButton;
        applySidebarState(false, !isNarrow(), { moveFocus: isNarrow() });
      });

      sidebarCollapseButton.addEventListener("click", () => {
        applySidebarState(true, true, { restoreFocus: true });
      });

      sidebarCloseButton.addEventListener("click", () => {
        applySidebarState(true, false, { restoreFocus: true });
      });

      if (sidebarBackdrop instanceof HTMLButtonElement) {
        sidebarBackdrop.addEventListener("click", () => {
          applySidebarState(true, false, { restoreFocus: true });
        });
      }

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && isNarrow() && !shell.classList.contains("sidebar-collapsed")) {
          event.preventDefault();
          applySidebarState(true, false, { restoreFocus: true });
          return;
        }

        if (
          event.key === "Tab" &&
          isNarrow() &&
          !shell.classList.contains("sidebar-collapsed")
        ) {
          const focusableElements = getFocusableElements();
          const firstFocusable = focusableElements[0];
          const lastFocusable = focusableElements.at(-1);

          if (!(firstFocusable instanceof HTMLElement) || !(lastFocusable instanceof HTMLElement)) {
            event.preventDefault();
            sidebar.focus();
            return;
          }

          if (event.shiftKey && document.activeElement === firstFocusable) {
            event.preventDefault();
            lastFocusable.focus();
          } else if (!event.shiftKey && document.activeElement === lastFocusable) {
            event.preventDefault();
            firstFocusable.focus();
          } else if (!sidebar.contains(document.activeElement)) {
            event.preventDefault();
            firstFocusable.focus();
          }
        }
      });

      media.addEventListener("change", () => {
        applySidebarState(isNarrow() ? true : getStoredCollapsed());
      });
    }

    const sidebarSearchInput = document.getElementById("sidebar-search-input");
    if (sidebarSearchInput instanceof HTMLInputElement && window.location.pathname.startsWith("/search")) {
      sidebarSearchInput.value = new URLSearchParams(window.location.search).get("q") ?? "";
    }
  })();
</script>
