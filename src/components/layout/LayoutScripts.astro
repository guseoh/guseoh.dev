---

<script is:inline>
  (() => {
    const root = document.documentElement;
    const themeButton = document.getElementById("theme-toggle");
    const themeMedia = window.matchMedia("(prefers-color-scheme: dark)");
    const label = themeButton?.querySelector(".theme-toggle__label");

    const getStoredTheme = () => {
      try {
        const stored = localStorage.getItem("theme");
        return stored === "light" || stored === "dark" ? stored : null;
      } catch {
        return null;
      }
    };

    const updateThemeButton = (theme) => {
      if (themeButton instanceof HTMLButtonElement) {
        const current = theme === "dark" ? "Dark" : "Light";
        themeButton.dataset.theme = theme;
        themeButton.setAttribute("aria-pressed", theme === "dark" ? "true" : "false");
        themeButton.setAttribute("aria-label", `현재 테마: ${current}. 테마를 전환합니다.`);
        themeButton.title = `현재 테마: ${current}`;

        if (label instanceof HTMLElement) {
          label.textContent = current;
        }
      }
    };

    const applyTheme = (theme, { persist = true, notify = true } = {}) => {
      const nextTheme = theme === "dark" ? "dark" : "light";
      root.setAttribute("data-theme", nextTheme);
      root.style.colorScheme = nextTheme;
      updateThemeButton(nextTheme);

      if (persist) {
        try {
          localStorage.setItem("theme", nextTheme);
        } catch {
        }
      }

      if (notify) {
        window.dispatchEvent(new CustomEvent("themechange", { detail: { theme: nextTheme } }));
      }
    };

    const currentTheme = root.getAttribute("data-theme") === "dark" ? "dark" : "light";
    applyTheme(currentTheme, { persist: false, notify: false });

    if (themeButton instanceof HTMLButtonElement) {
      themeButton.addEventListener("click", () => {
        const now = root.getAttribute("data-theme") === "dark" ? "dark" : "light";
        applyTheme(now === "dark" ? "light" : "dark");
      });
    }

    window.addEventListener("storage", (event) => {
      if (event.key === "theme" && (event.newValue === "light" || event.newValue === "dark")) {
        applyTheme(event.newValue, { persist: false });
      }
    });

    themeMedia.addEventListener("change", (event) => {
      if (!getStoredTheme()) {
        applyTheme(event.matches ? "dark" : "light", { persist: false });
      }
    });

    const shell = document.querySelector(".site-shell");
    const sidebar = document.getElementById("site-sidebar");
    const sidebarOpenButton = document.getElementById("sidebar-open");
    const sidebarCollapseButton = document.getElementById("sidebar-collapse-toggle");
    const sidebarCloseButton = document.getElementById("sidebar-close");
    const sidebarBackdrop = document.getElementById("sidebar-backdrop");

    if (
      shell instanceof HTMLElement &&
      sidebar instanceof HTMLElement &&
      sidebarOpenButton instanceof HTMLButtonElement &&
      sidebarCollapseButton instanceof HTMLButtonElement &&
      sidebarCloseButton instanceof HTMLButtonElement
    ) {
      const storageKey = "blog-left-sidebar-collapsed";
      const media = window.matchMedia("(max-width: 980px)");
      const isNarrow = () => media.matches;

      const getStoredCollapsed = () => {
        try {
          return localStorage.getItem(storageKey) === "true";
        } catch {
          return false;
        }
      };

      const setStoredCollapsed = (collapsed) => {
        try {
          localStorage.setItem(storageKey, collapsed ? "true" : "false");
        } catch {
        }
      };

      const applySidebarState = (collapsed, persist = false) => {
        const narrow = isNarrow();
        const shouldCollapse = Boolean(collapsed);
        const openLabel = narrow ? "사이드바 열기" : "탐색 펼치기";

        shell.classList.toggle("sidebar-collapsed", shouldCollapse);
        document.documentElement.classList.toggle("left-sidebar-collapsed", !narrow && shouldCollapse);
        document.body.classList.toggle("has-sidebar-open", narrow && !shouldCollapse);
        sidebar.setAttribute("aria-hidden", shouldCollapse ? "true" : "false");
        sidebarOpenButton.hidden = !shouldCollapse;
        sidebarOpenButton.setAttribute("aria-label", openLabel);
        sidebarOpenButton.setAttribute("aria-expanded", shouldCollapse ? "false" : "true");
        sidebarOpenButton.title = openLabel;
        sidebarCollapseButton.hidden = narrow || shouldCollapse;
        sidebarCollapseButton.setAttribute("aria-expanded", shouldCollapse ? "false" : "true");
        sidebarCollapseButton.setAttribute("aria-label", "탐색 접기");
        sidebarCloseButton.hidden = !narrow;

        if (sidebarBackdrop instanceof HTMLButtonElement) {
          sidebarBackdrop.hidden = shouldCollapse || !narrow;
        }

        if (!narrow && persist) {
          setStoredCollapsed(shouldCollapse);
        }
      };

      applySidebarState(isNarrow() ? true : getStoredCollapsed());

      sidebarOpenButton.addEventListener("click", () => {
        applySidebarState(false, !isNarrow());
      });

      sidebarCollapseButton.addEventListener("click", () => {
        applySidebarState(true, true);
        sidebarOpenButton.focus();
      });

      sidebarCloseButton.addEventListener("click", () => {
        applySidebarState(true);
      });

      if (sidebarBackdrop instanceof HTMLButtonElement) {
        sidebarBackdrop.addEventListener("click", () => {
          applySidebarState(true);
        });
      }

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && isNarrow() && !shell.classList.contains("sidebar-collapsed")) {
          applySidebarState(true);
          sidebarOpenButton.focus();
        }
      });

      media.addEventListener("change", () => {
        applySidebarState(isNarrow() ? true : getStoredCollapsed());
      });
    }

    const sidebarSearchInput = document.getElementById("sidebar-search-input");
    if (sidebarSearchInput instanceof HTMLInputElement && window.location.pathname.startsWith("/search")) {
      sidebarSearchInput.value = new URLSearchParams(window.location.search).get("q") ?? "";
    }
  })();
</script>
