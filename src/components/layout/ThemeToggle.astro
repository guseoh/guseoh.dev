---

<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label="현재 테마: System. 테마를 전환합니다."
  data-theme="light"
  data-theme-mode="system"
  title="현재 테마: System"
>
  <span class="theme-toggle__icon" aria-hidden="true">
    <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" focusable="false">
      <path d="M20 14.25A8.25 8.25 0 0 1 9.75 4a8.26 8.26 0 1 0 10.25 10.25Z"></path>
    </svg>
    <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" focusable="false">
      <circle cx="12" cy="12" r="3.6"></circle>
      <path d="M12 2.5v2.2M12 19.3v2.2M21.5 12h-2.2M4.7 12H2.5M18.7 5.3l-1.6 1.6M6.9 17.1l-1.6 1.6M18.7 18.7l-1.6-1.6M6.9 6.9L5.3 5.3"></path>
    </svg>
  </span>
  <span class="theme-toggle__label">System</span>
</button>
