---
import CategoryIcon from "../CategoryIcon.astro";
import type { RelatedPostResult } from "../../utils/relatedPosts";
import { normalizeCategory } from "../../utils/categories";
import { formatTagName } from "../../utils/tags";
import { formatPostDate, getPostDescription, getPostPath, getReadingTime } from "../../utils/posts";

interface Props {
  relatedPosts: RelatedPostResult[];
}

const { relatedPosts } = Astro.props as Props;
---

{
  relatedPosts.length > 0 && (
    <section class="post-related" aria-labelledby="post-related-title">
      <div class="post-related__header">
        <p class="post-related__label">Related</p>
        <h2 id="post-related-title">함께 읽으면 좋은 글</h2>
      </div>

      <div class="post-related__grid">
        {relatedPosts.map(({ post, commonTags, reasons }) => {
          const categoryName = post.data.category?.trim() || "Uncategorized";
          const categorySlug = normalizeCategory(categoryName);
          const visibleCommonTags = commonTags.slice(0, 3);

          return (
            <a class="post-related__card" href={getPostPath(post)}>
              <span class="post-related__meta">
                <CategoryIcon category={categoryName} />
                <span>{categoryName}</span>
                <span aria-hidden="true">·</span>
                <time datetime={post.data.date.toISOString()}>{formatPostDate(post.data.date)}</time>
              </span>
              <strong>{post.data.title}</strong>
              <span class="post-related__description">{getPostDescription(post)}</span>
              <span class="post-related__footer">
                <span>{getReadingTime(post)}</span>
                {reasons.length > 0 && <span>{reasons.join(" · ")}</span>}
              </span>
              {visibleCommonTags.length > 0 && (
                <span class="post-related__tags" aria-label="공통 태그">
                  {visibleCommonTags.map((tag) => (
                    <span>#{formatTagName(tag)}</span>
                  ))}
                </span>
              )}
              <span class="sr-only">{categorySlug} 카테고리 관련 글로 이동</span>
            </a>
          );
        })}
      </div>
    </section>
  )
}
