---
interface Props {
  postId: string;
}

const { postId } = Astro.props as Props;
---

<div class="post-reading-progress" aria-hidden="true">
  <span class="post-reading-progress__bar" data-reading-progress-bar></span>
</div>

<aside class="post-resume" data-post-resume hidden aria-label="이전 읽기 위치">
  <p>이전에 읽던 위치가 있습니다.</p>
  <div class="post-resume__actions">
    <button type="button" data-post-resume-continue>이어서 읽기</button>
    <button type="button" data-post-resume-dismiss>닫기</button>
  </div>
</aside>

<script is:inline define:vars={{ postId }}>
  (() => {
    const initReadingProgress = () => {
      const content = document.querySelector(".post__content");
      const bar = document.querySelector("[data-reading-progress-bar]");
      const resume = document.querySelector("[data-post-resume]");
      if (!(content instanceof HTMLElement) || !(bar instanceof HTMLElement) || !(resume instanceof HTMLElement)) return;

    const continueButton = resume.querySelector("[data-post-resume-continue]");
    const dismissButton = resume.querySelector("[data-post-resume-dismiss]");
    if (!(continueButton instanceof HTMLButtonElement) || !(dismissButton instanceof HTMLButtonElement)) return;

    const STORAGE_KEY = `post-reading-position:${postId}`;
    const DISMISS_KEY = `post-reading-position-dismissed:${postId}`;
    const MAX_AGE_DAYS = 90;
    const COMPLETE_THRESHOLD = 0.95;
    const SAVE_INTERVAL_MS = 1500;
    let frame = 0;
    let lastSaveAt = 0;
    let currentProgress = 0;
    let activeHeadingId = "";
    let activeHeadingOffset = 0;
    let storageAvailable = true;

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

    const safeStorage = {
      get(key) {
        if (!storageAvailable) return null;
        try {
          return window.localStorage.getItem(key);
        } catch {
          storageAvailable = false;
          return null;
        }
      },
      set(key, value) {
        if (!storageAvailable) return;
        try {
          window.localStorage.setItem(key, value);
        } catch {
          storageAvailable = false;
        }
      },
      remove(key) {
        if (!storageAvailable) return;
        try {
          window.localStorage.removeItem(key);
        } catch {
          storageAvailable = false;
        }
      }
    };

    const getBounds = () => {
      const start = content.getBoundingClientRect().top + window.scrollY;
      const end = start + content.scrollHeight;
      const maxScroll = Math.max(start, end - window.innerHeight);
      return { start, end, maxScroll };
    };

    const readProgress = () => {
      const { start, maxScroll } = getBounds();
      if (maxScroll <= start) return 1;
      return clamp((window.scrollY - start) / (maxScroll - start), 0, 1);
    };

    const readActiveHeading = () => {
      const headings = Array.from(content.querySelectorAll("h2[id], h3[id], h4[id]"));
      let active = null;
      const y = window.scrollY + 160;

      for (const heading of headings) {
        if (!(heading instanceof HTMLElement)) continue;
        if (heading.offsetTop <= y) {
          active = heading;
        } else {
          break;
        }
      }

      activeHeadingId = active?.id ?? "";
      activeHeadingOffset = active ? Math.max(0, window.scrollY - active.offsetTop) : 0;
    };

    const savePosition = ({ force = false } = {}) => {
      if (!storageAvailable) return;
      const now = Date.now();
      if (!force && now - lastSaveAt < SAVE_INTERVAL_MS) return;
      lastSaveAt = now;

      const payload = {
        headingId: activeHeadingId,
        headingOffset: Math.round(activeHeadingOffset),
        progress: Number(currentProgress.toFixed(4)),
        savedAt: new Date().toISOString()
      };

      safeStorage.set(STORAGE_KEY, JSON.stringify(payload));
    };

    const update = () => {
      frame = 0;
      currentProgress = readProgress();
      bar.style.transform = `scaleX(${currentProgress})`;
      readActiveHeading();
      savePosition();
    };

    const scheduleUpdate = () => {
      if (frame) return;
      frame = window.requestAnimationFrame(update);
    };

    const parseRecord = () => {
      const raw = safeStorage.get(STORAGE_KEY);
      if (!raw) return null;

      try {
        const record = JSON.parse(raw);
        const savedAt = new Date(record.savedAt);
        const ageMs = Date.now() - savedAt.valueOf();
        const maxAgeMs = MAX_AGE_DAYS * 24 * 60 * 60 * 1000;

        if (!Number.isFinite(savedAt.valueOf()) || ageMs > maxAgeMs) {
          safeStorage.remove(STORAGE_KEY);
          return null;
        }

        if (Number(record.progress) >= COMPLETE_THRESHOLD) {
          return null;
        }

        return record;
      } catch {
        safeStorage.remove(STORAGE_KEY);
        return null;
      }
    };

    const shouldShowResume = (record) => {
      if (!record) return false;
      if (window.location.hash) return false;
      try {
        if (window.sessionStorage.getItem(DISMISS_KEY) === "true") return false;
      } catch {
      }
      return Number(record.progress) > 0.05;
    };

    const restoreRecord = (record) => {
      const { start, maxScroll } = getBounds();
      const heading = record.headingId ? document.getElementById(record.headingId) : null;
      const targetY = heading instanceof HTMLElement
        ? heading.offsetTop + Number(record.headingOffset || 0)
        : start + (maxScroll - start) * clamp(Number(record.progress || 0), 0, 1);

      window.scrollTo({ top: Math.max(0, targetY), behavior: "smooth" });
      window.setTimeout(() => {
        scheduleUpdate();
        window.dispatchEvent(new Event("hashchange"));
      }, 250);
    };

    const dismissResume = () => {
      resume.hidden = true;
      try {
        window.sessionStorage.setItem(DISMISS_KEY, "true");
      } catch {
      }
    };

    const record = parseRecord();
    if (shouldShowResume(record)) {
      resume.hidden = false;
    }

    continueButton.addEventListener("click", () => {
      if (record) {
        restoreRecord(record);
      }
      dismissResume();
    });

    dismissButton.addEventListener("click", dismissResume);
    window.addEventListener("scroll", scheduleUpdate, { passive: true });
    window.addEventListener("resize", scheduleUpdate);
    window.addEventListener("load", scheduleUpdate);
    window.addEventListener("beforeunload", () => savePosition({ force: true }));
    window.addEventListener("pagehide", () => savePosition({ force: true }));

    if ("ResizeObserver" in window) {
      const observer = new ResizeObserver(scheduleUpdate);
      observer.observe(content);
    }

    for (const image of content.querySelectorAll("img")) {
      if (image instanceof HTMLImageElement && !image.complete) {
        image.addEventListener("load", scheduleUpdate, { once: true });
      }
    }

      scheduleUpdate();
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initReadingProgress, { once: true });
    } else {
      initReadingProgress();
    }
  })();
</script>
