---
export interface TocHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: TocHeading[];
}

const { headings } = Astro.props as Props;
---

{
  headings.length > 0 && (
    <>
      <section class="post-toc-mobile" aria-label="Document table of contents">
        <button
          id="post-toc-toggle"
          class="post-toc-mobile__toggle"
          type="button"
          aria-expanded="false"
          aria-controls="post-toc-mobile-panel"
        >
          <span>이 글의 목차</span>
          <span class="post-toc-mobile__chevron" aria-hidden="true"></span>
        </button>
        <nav id="post-toc-mobile-panel" class="post-toc-mobile__panel" aria-label="접이식 글 목차" hidden>
          <ul class="post-toc-mobile__list">
            {headings.map((heading) => (
              <li class:list={["post-toc-mobile__item", `depth-${heading.depth}`]}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      </section>

      <aside class="post-toc" aria-label="Document table of contents">
        <p class="post-toc__title">이 글의 목차</p>
        <ul class="post-toc__list">
          {headings.map((heading) => (
            <li class:list={["post-toc__item", `depth-${heading.depth}`]}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ul>
      </aside>

      <script is:inline>
        (() => {
          const initializeToc = () => {
            const tocRoot = document.querySelector(".post-view");
            if (!(tocRoot instanceof HTMLElement) || tocRoot.dataset.tocReady === "true") return;
            tocRoot.dataset.tocReady = "true";

            const links = Array.from(
              document.querySelectorAll(".post-toc__item a, .post-toc-mobile__item a")
            );
            if (links.length === 0) return;
            const mobileToggle = document.getElementById("post-toc-toggle");
            const mobilePanel = document.getElementById("post-toc-mobile-panel");
            const compactMedia = window.matchMedia("(max-width: 1439px)");

            const entries = links
              .map((link) => {
                if (!(link instanceof HTMLAnchorElement)) return null;

                const href = link.getAttribute("href") || "";
                if (!href.startsWith("#")) return null;

                const id = decodeURIComponent(href.slice(1));
                const section = document.getElementById(id);
                if (!(section instanceof HTMLElement)) return null;

                return { link, section };
              })
              .filter((entry) => entry !== null);

            if (entries.length === 0) return;

            const sections = Array.from(new Set(entries.map((entry) => entry.section)));
            const desktopToc = document.querySelector(".post-toc");
            const motionMedia = window.matchMedia("(prefers-reduced-motion: reduce)");
            let activeSection = null;
            let tocInteractionUntil = 0;

            const markTocInteraction = () => {
              tocInteractionUntil = Date.now() + 1200;
            };

            if (desktopToc instanceof HTMLElement) {
              desktopToc.addEventListener("wheel", markTocInteraction, { passive: true });
              desktopToc.addEventListener("touchstart", markTocInteraction, { passive: true });
              desktopToc.addEventListener("pointerdown", markTocInteraction, { passive: true });
            }

            const revealDesktopLink = (section) => {
              if (!(desktopToc instanceof HTMLElement) || Date.now() < tocInteractionUntil) return;

              const activeLink = entries.find((entry) =>
                entry.section === section && entry.link.closest(".post-toc") === desktopToc
              )?.link;
              if (!(activeLink instanceof HTMLAnchorElement)) return;

              const containerRect = desktopToc.getBoundingClientRect();
              const linkRect = activeLink.getBoundingClientRect();
              const outsideTop = linkRect.top < containerRect.top;
              const outsideBottom = linkRect.bottom > containerRect.bottom;
              if (!outsideTop && !outsideBottom) return;

              const targetTop = activeLink.offsetTop - (desktopToc.clientHeight - activeLink.offsetHeight) / 2;
              desktopToc.scrollTo({
                top: Math.max(0, targetTop),
                behavior: motionMedia.matches ? "auto" : "smooth"
              });
            };

            const applyActive = () => {
              const readingOffset = Math.min(220, Math.max(128, window.innerHeight * 0.24));
              const currentY = window.scrollY + readingOffset;
              const atPageEnd = Math.ceil(window.scrollY + window.innerHeight) >= document.documentElement.scrollHeight - 2;
              let nextSection = atPageEnd ? sections[sections.length - 1] : sections[0];

              if (!atPageEnd) {
                for (const section of sections) {
                  if (section.offsetTop <= currentY) {
                    nextSection = section;
                  } else {
                    break;
                  }
                }
              }

              if (activeSection === nextSection) return;
              activeSection = nextSection;

              for (const entry of entries) {
                const isActive = entry.section === activeSection;
                entry.link.classList.toggle("is-active", isActive);
                if (isActive) {
                  entry.link.setAttribute("aria-current", "location");
                } else {
                  entry.link.removeAttribute("aria-current");
                }
              }

              revealDesktopLink(activeSection);
            };

            let activeFrame = 0;
            const scheduleActive = () => {
              if (activeFrame) return;

              activeFrame = window.requestAnimationFrame(() => {
                activeFrame = 0;
                applyActive();
              });
            };

            const applyMobileTocState = (open, { restoreFocus = false } = {}) => {
              if (
                !(mobileToggle instanceof HTMLButtonElement) ||
                !(mobilePanel instanceof HTMLElement)
              ) {
                return;
              }

              const shouldOpen = Boolean(open);
              mobileToggle.setAttribute("aria-expanded", shouldOpen ? "true" : "false");
              mobilePanel.hidden = !shouldOpen;

              if (restoreFocus) {
                mobileToggle.focus();
              }
            };

            if (mobileToggle instanceof HTMLButtonElement && mobilePanel instanceof HTMLElement) {
              mobileToggle.addEventListener("click", () => {
                applyMobileTocState(mobileToggle.getAttribute("aria-expanded") !== "true");
              });

              mobilePanel.addEventListener("click", (event) => {
                if (event.target instanceof HTMLAnchorElement) {
                  applyMobileTocState(false);
                  window.setTimeout(scheduleActive, 0);
                }
              });

              window.addEventListener("keydown", (event) => {
                if (event.key === "Escape" && mobileToggle.getAttribute("aria-expanded") === "true") {
                  event.preventDefault();
                  applyMobileTocState(false, { restoreFocus: true });
                }
              });

              compactMedia.addEventListener("change", () => applyMobileTocState(false));
            }

            applyActive();
            window.addEventListener("scroll", scheduleActive, { passive: true });
            window.addEventListener("resize", scheduleActive);
            window.addEventListener("hashchange", scheduleActive);
          };

          if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initializeToc, { once: true });
          } else {
            initializeToc();
          }
        })();
      </script>
    </>
  )
}
