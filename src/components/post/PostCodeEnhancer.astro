<script is:inline>
  (() => {
    const blocks = Array.from(document.querySelectorAll(".post pre"));
    if (blocks.length === 0) return;

    const languageLabels = new Map([
      ["java", "Java"],
      ["js", "JavaScript"],
      ["javascript", "JavaScript"],
      ["ts", "TypeScript"],
      ["typescript", "TypeScript"],
      ["sql", "SQL"],
      ["bash", "Bash"],
      ["sh", "Bash"],
      ["yaml", "YAML"],
      ["yml", "YAML"],
      ["html", "HTML"],
      ["css", "CSS"],
      ["json", "JSON"],
      ["xml", "XML"],
      ["properties", "Properties"],
      ["text", "Code"],
      ["plaintext", "Code"]
    ]);

    const getLanguageKey = (pre) => {
      const fromData = pre.dataset.language || "";
      if (fromData.trim().length > 0) return fromData;

      const code = pre.querySelector("code");
      const className = `${pre.className} ${code?.className ?? ""}`;
      const match = className.match(/language-([A-Za-z0-9_-]+)/);
      return match?.[1] ?? "";
    };

    const getLanguageLabel = (pre) => {
      const key = getLanguageKey(pre).trim().toLowerCase();
      return languageLabels.get(key) ?? (key.length > 0 ? key[0].toUpperCase() + key.slice(1) : "Code");
    };

    const getMetaValue = (pre, code, marker, key) => marker?.dataset[key] || pre.dataset[key] || code?.dataset[key] || "";

    const expandHighlightedLines = (value) => {
      const lines = new Set();

      for (const token of value.split(",")) {
        const trimmed = token.trim();
        if (!trimmed) continue;

        const [startValue, endValue] = trimmed.split("-");
        const start = Number(startValue);
        const end = endValue ? Number(endValue) : start;

        if (!Number.isInteger(start) || !Number.isInteger(end) || start < 1 || end < start) continue;

        for (let line = start; line <= end; line += 1) {
          lines.add(line);
        }
      }

      return lines;
    };

    const applyLineMetadata = (wrapper, pre, code, marker) => {
      const showLineNumbers = getMetaValue(pre, code, marker, "showLineNumbers") === "true";
      const highlightedLines = expandHighlightedLines(getMetaValue(pre, code, marker, "highlightLines"));
      const lines = Array.from(code?.querySelectorAll(":scope > .line") ?? []);

      if (showLineNumbers) {
        wrapper.classList.add("code-block--line-numbers");
        pre.classList.add("has-line-numbers");
      }

      if (highlightedLines.size > 0) {
        wrapper.classList.add("code-block--highlight-lines");
      }

      lines.forEach((line, lineIndex) => {
        if (!(line instanceof HTMLElement)) return;

        const lineNumber = lineIndex + 1;
        if (showLineNumbers) {
          line.dataset.lineNumber = String(lineNumber);
        }

        if (highlightedLines.has(lineNumber)) {
          line.classList.add("is-highlighted");
        }
      });
    };

    for (const [index, pre] of blocks.entries()) {
      if (!(pre instanceof HTMLPreElement) || pre.parentElement?.classList.contains("code-block")) continue;
      const code = pre.querySelector("code");
      const metaMarker = pre.previousElementSibling instanceof HTMLElement && pre.previousElementSibling.classList.contains("code-block-meta")
        ? pre.previousElementSibling
        : null;

      const wrapper = document.createElement("div");
      wrapper.className = "code-block";
      pre.parentNode?.insertBefore(wrapper, pre);

      const header = document.createElement("div");
      header.className = "code-block__header";

      const meta = document.createElement("div");
      meta.className = "code-block__meta";

      const language = document.createElement("span");
      language.className = "code-block__language";
      language.textContent = getLanguageLabel(pre);
      meta.append(language);

      const codeTitle = getMetaValue(pre, code, metaMarker, "codeTitle").trim();
      if (codeTitle.length > 0) {
        const title = document.createElement("span");
        title.className = "code-block__title";
        title.textContent = codeTitle;
        title.title = codeTitle;
        meta.append(title);
      }

      const button = document.createElement("button");
      button.type = "button";
      button.className = "code-copy-button";
      button.textContent = "Copy";
      button.setAttribute("aria-label", "코드 블록 복사");

      const status = document.createElement("span");
      status.id = `code-copy-status-${index}`;
      status.className = "sr-only";
      status.setAttribute("aria-live", "polite");
      status.setAttribute("aria-atomic", "true");
      button.setAttribute("aria-describedby", status.id);

      header.append(meta, button, status);
      wrapper.append(header, pre);
      applyLineMetadata(wrapper, pre, code, metaMarker);
      metaMarker?.remove();

      const copyText = async (text) => {
        if (window.navigator?.clipboard && window.isSecureContext) {
          await window.navigator.clipboard.writeText(text);
          return "copied";
        }

        if (typeof document.createElement !== "function") {
          return "selected";
        }

        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "true");
        textarea.style.position = "fixed";
        textarea.style.top = "-1000px";
        textarea.style.left = "-1000px";
        document.body.append(textarea);
        textarea.select();

        const execCopy = document["exec" + "Command"];
        const copied = typeof execCopy === "function" && execCopy.call(document, "copy");
        textarea.remove();

        return copied ? "copied" : "selected";
      };

      const getCodeText = () => {
        const code = pre.querySelector("code");
        const lines = Array.from(code?.querySelectorAll(":scope > .line") ?? []);

        if (lines.length > 0) {
          return lines.map((line) => line.textContent ?? "").join("\n");
        }

        return code?.textContent ?? pre.textContent ?? "";
      };

      const announce = (message) => {
        if (status.textContent === message) {
          status.textContent = "";
          window.setTimeout(() => {
            status.textContent = message;
          }, 20);
          return;
        }

        status.textContent = message;
      };

      button.addEventListener("click", async () => {
        try {
          const result = await copyText(getCodeText());
          button.textContent = result === "copied" ? "Copied" : "Selected";
          announce(result === "copied"
            ? "코드가 복사되었습니다."
            : "코드를 선택했습니다. 직접 복사해 주세요.");
          window.setTimeout(() => {
            button.textContent = "Copy";
          }, 1400);
        } catch {
          button.textContent = "Selected";
          announce("코드를 복사하지 못했습니다. 직접 선택해서 복사해 주세요.");
          window.setTimeout(() => {
            button.textContent = "Copy";
          }, 1400);
        }
      });
    }
  })();
</script>
