<section class="comments-wrap" aria-label="Comment section">
  <h2 class="comments-wrap__title">Comments</h2>
  <p class="comments-wrap__description">Comments require GitHub sign-in.</p>

  <div id="utterances-comments" class="comments-wrap__public" aria-busy="true">
    <div class="comments-loading" data-comments-loading role="status" aria-live="polite">
      <span class="comments-loading__spinner" aria-hidden="true"></span>
      <span>댓글을 불러오는 중입니다.</span>
    </div>
  </div>

  <script is:inline>
    (() => {
      const target = document.getElementById("utterances-comments");
      if (!target) return;
      if (target.dataset.commentsInitialized === "true") return;
      target.dataset.commentsInitialized = "true";

      const loading = target.querySelector("[data-comments-loading]");
      let frameObserver;

      const finishLoading = () => {
        if (loading instanceof HTMLElement) {
          loading.hidden = true;
        }
        target.classList.add("is-ready");
        target.removeAttribute("aria-busy");
        frameObserver?.disconnect();
      };

      const watchFrame = () => {
        const iframe = target.querySelector("iframe.utterances-frame");
        if (!(iframe instanceof HTMLIFrameElement)) return;
        if (iframe.dataset.commentsLoadWatched === "true") return;

        iframe.dataset.commentsLoadWatched = "true";
        iframe.addEventListener("load", finishLoading, { once: true });
      };

      frameObserver = new MutationObserver(watchFrame);
      frameObserver.observe(target, { childList: true, subtree: true });
      watchFrame();

      const getUtterancesTheme = () =>
        document.documentElement.getAttribute("data-theme") === "dark" ? "github-dark" : "github-light";

      const syncTheme = () => {
        const iframe = target.querySelector("iframe.utterances-frame");
        if (!(iframe instanceof HTMLIFrameElement) || !iframe.contentWindow) return;

        iframe.contentWindow.postMessage(
          { type: "set-theme", theme: getUtterancesTheme() },
          "https://utteranc.es"
        );
      };

      const themeObserver = new MutationObserver(syncTheme);
      themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-theme"]
      });

      const loadComments = () => {
        if (target.dataset.loaded === "true") return;
        target.dataset.loaded = "true";

        const script = document.createElement("script");
        script.src = "https://utteranc.es/client.js";
        script.setAttribute("repo", "guseoh/guseoh.github.io");
        script.setAttribute("issue-term", "pathname");
        script.setAttribute("label", "comment");
        script.setAttribute("theme", getUtterancesTheme());
        script.setAttribute("crossorigin", "anonymous");
        script.addEventListener("load", () => {
          watchFrame();
          window.setTimeout(syncTheme, 0);
        });
        script.async = true;
        target.append(script);
      };

      if ("IntersectionObserver" in window) {
        const visibilityObserver = new IntersectionObserver(
          (entries) => {
            if (!entries.some((entry) => entry.isIntersecting)) return;
            visibilityObserver.disconnect();
            loadComments();
          },
          { rootMargin: "400px 0px" }
        );

        visibilityObserver.observe(target);
      } else {
        loadComments();
      }
    })();
  </script>
</section>

