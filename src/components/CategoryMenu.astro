---
import CategoryIcon from "./CategoryIcon.astro";
import type { CategoryTreeGroup } from "../utils/categories";

interface Props {
  groups: CategoryTreeGroup[];
  idPrefix: string;
  variant?: "sidebar" | "home" | "page";
  totalCount?: number;
  currentPath?: string;
  currentCategory?: string;
  showAllLink?: boolean;
  label?: string;
}

const {
  groups,
  idPrefix,
  variant = "page",
  totalCount,
  currentPath = "",
  currentCategory = "",
  showAllLink = false,
  label = "카테고리 탐색"
} = Astro.props as Props;

const normalizePath = (path: string) => path.replace(/\/+$/, "") || "/";
const normalizedCurrentPath = normalizePath(currentPath);
const showAllPostsLink = showAllLink && typeof totalCount === "number";
const isAllPostsActive = normalizedCurrentPath === "/blog" || normalizedCurrentPath.startsWith("/blog/page");
const isChildActive = (child: CategoryTreeGroup["children"][number]) =>
  currentCategory === child.slug ||
  (child.href ? normalizePath(child.href) === normalizedCurrentPath : false);
---

<nav class:list={["category-menu", `category-menu--${variant}`]} aria-label={label} data-category-menu>
  {
    showAllPostsLink && (
      <a
        class:list={["category-menu__all", isAllPostsActive && "is-active"]}
        href="/blog/"
        aria-current={isAllPostsActive ? "page" : undefined}
        data-sidebar-current={variant === "sidebar" && isAllPostsActive ? "page" : undefined}
      >
        <span>전체 글</span>
        <strong>({totalCount})</strong>
      </a>
    )
  }

  {groups.map((group, index) => {
    const hasChildren = group.children.length > 0;
    const isGroupPathActive = group.href ? normalizePath(group.href) === normalizedCurrentPath : false;
    const isActiveGroup = currentCategory === group.slug || isGroupPathActive || group.children.some(isChildActive);
    const isExpanded = isActiveGroup || (variant === "page" && index === 0);
    const panelId = `${idPrefix}-${group.slug}-panel`;

    return (
      <div class:list={["category-menu__group", isActiveGroup && "is-active"]}>
        <div class:list={["category-menu__parent", !hasChildren && "category-menu__parent--leaf"]}>
          <a
            class="category-menu__parent-link"
            href={group.href}
            aria-current={isGroupPathActive ? "page" : undefined}
            data-sidebar-current={variant === "sidebar" && isGroupPathActive ? "page" : undefined}
          >
            <span class="category-menu__meta">
              <CategoryIcon category={group.name} />
              <span class="category-menu__title">{group.name}</span>
            </span>
            <span class="category-menu__count">({group.count})</span>
          </a>

          {hasChildren && (
            <button
              class="category-menu__toggle"
              type="button"
              aria-expanded={isExpanded ? "true" : "false"}
              aria-label={`${group.name} 하위 항목 ${isExpanded ? "접기" : "펼치기"}`}
              aria-controls={panelId}
              data-category-name={group.name}
              data-category-toggle
            >
              <span class="category-menu__chevron" aria-hidden="true"></span>
            </button>
          )}
        </div>

        {hasChildren && (
          <div id={panelId} class="category-menu__children" hidden={!isExpanded}>
            {group.children.map((child) => {
              const isActive = isChildActive(child);
              const currentType = currentCategory === child.slug ? "category" : "page";

              return child.href ? (
                <a
                  class:list={["category-menu__child", isActive && "is-active"]}
                  href={child.href}
                  aria-current={isActive ? "page" : undefined}
                  data-sidebar-current={variant === "sidebar" && isActive ? currentType : undefined}
                >
                  <span class="category-menu__child-label">
                    {child.categoryIcon && <CategoryIcon category={child.categoryIcon} />}
                    <span>{child.name}</span>
                  </span>
                  <strong>({child.count})</strong>
                </a>
              ) : (
                <span class="category-menu__child category-menu__child--planned" aria-disabled="true">
                  <span class="category-menu__child-label">
                    {child.categoryIcon && <CategoryIcon category={child.categoryIcon} />}
                    <span>{child.name}</span>
                  </span>
                  <small>준비 중</small>
                </span>
              );
            })}
          </div>
        )}
      </div>
    );
  })}
</nav>

<script is:inline>
  (() => {
    const menus = document.querySelectorAll("[data-category-menu]:not([data-category-menu-ready])");

    for (const menu of menus) {
      menu.setAttribute("data-category-menu-ready", "true");

      menu.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const button = target.closest("[data-category-toggle]");
        if (!(button instanceof HTMLButtonElement) || !menu.contains(button)) return;

        const panelId = button.getAttribute("aria-controls");
        if (!panelId) return;

        const panel = document.getElementById(panelId);
        if (!(panel instanceof HTMLElement)) return;

        const isExpanded = button.getAttribute("aria-expanded") === "true";
        const nextExpanded = !isExpanded;
        const categoryName = button.dataset.categoryName ?? button.textContent?.trim() ?? "카테고리";

        button.setAttribute("aria-expanded", nextExpanded ? "true" : "false");
        button.setAttribute("aria-label", `${categoryName} 하위 항목 ${nextExpanded ? "접기" : "펼치기"}`);
        panel.hidden = !nextExpanded;
      });
    }
  })();
</script>
