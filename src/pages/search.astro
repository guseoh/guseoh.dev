---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";
import { SITE_DESCRIPTION, sortPostsByDate } from "../utils/posts";

const posts = sortPostsByDate(await getCollection("blog", ({ data }) => !data.draft));

const searchablePosts = posts.map((post) => ({
  post,
  searchText: [post.data.title, post.data.description, post.data.category, ...post.data.tags]
    .join(" ")
    .toLowerCase()
}));
---

<BaseLayout title="devjune.dev | Search" description={`검색 결과 - ${SITE_DESCRIPTION}`}>
  <section class="hero">
    <h1>Search</h1>
    <p id="search-status">검색어를 입력하면 결과가 표시됩니다.</p>
    <form class="search-page-form" action="/search/" method="get" role="search">
      <label class="sr-only" for="search-page-input">검색어</label>
      <input id="search-page-input" name="q" type="search" placeholder="Spring, OS, Board" />
      <button type="submit">Search</button>
    </form>
  </section>

  <ul class="post-list search-results" data-search-list style="margin-top: 1rem;">
    {searchablePosts.map(({ post, searchText }) => (
      <li data-search-item data-search-text={searchText}>
        <PostCard post={post} />
      </li>
    ))}
  </ul>

  <script is:inline>
    (() => {
      const params = new URLSearchParams(window.location.search);
      const query = (params.get("q") ?? "").trim().toLowerCase();
      const input = document.getElementById("search-page-input");
      const searchItems = Array.from(document.querySelectorAll("[data-search-item]"));
      const status = document.getElementById("search-status");

      if (input instanceof HTMLInputElement) {
        input.value = params.get("q") ?? "";
      }

      let visibleCount = 0;
      for (const item of searchItems) {
        if (!(item instanceof HTMLElement)) continue;
        const text = item.dataset.searchText ?? "";
        const isVisible = query.length === 0 ? true : text.includes(query);
        item.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      }

      if (status) {
        if (query.length === 0) {
          status.textContent = `전체 ${searchItems.length}개의 검색 결과를 찾았습니다.`;
        } else {
          status.textContent = `"${query}" 검색 결과 ${visibleCount}개`;
        }
      }
    })();
  </script>
</BaseLayout>

