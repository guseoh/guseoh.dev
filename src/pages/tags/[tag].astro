---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { buildTagSummary, normalizeTag } from "../../utils/tags";
import { getPublishedPosts } from "../../utils/content/posts";
import { SITE_DESCRIPTION, sortPostsByDate } from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tagSet = new Set(posts.flatMap((post) => post.data.tags.map((tag) => normalizeTag(tag))));

  return Array.from(tagSet).map((tag) => {
    const filtered = posts.filter((post) =>
      post.data.tags.some((entryTag) => normalizeTag(entryTag) === tag)
    );

    return {
      params: { tag },
      props: { tag, posts: sortPostsByDate(filtered) }
    };
  });
}

const { tag, posts } = Astro.props as {
  tag: string;
  posts: CollectionEntry<"blog">[];
};

const allPosts = await getPublishedPosts();
const tagSummary = buildTagSummary(allPosts);
const activeTag = tagSummary.find((entry) => entry.tag === tag);
const tagName = activeTag?.name ?? tag;
---

<BaseLayout title={`devjune.dev | #${tagName}`} description={`#${tagName} 태그 글 목록 - ${SITE_DESCRIPTION}`}>
  <section class="hero">
    <h1>#{tagName}</h1>
    <p>{posts.length}개의 게시글이 이 태그에 연결되어 있습니다.</p>
  </section>

  <nav class="archive-filter-list" aria-label="Tag filters">
    {tagSummary.map(({ tag: tagSlug, name, count }) => (
      <a class:list={["archive-filter-pill", tagSlug === tag && "is-active"]} href={`/tags/${tagSlug}/`}>
        <span>#{name}</span>
        <strong>{count}</strong>
      </a>
    ))}
  </nav>

  <ul class="post-list" style="margin-top: 1rem;">
    {posts.map((post) => (
      <li>
        <PostCard post={post} />
      </li>
    ))}
  </ul>
</BaseLayout>
