---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildSeriesSummary } from "../../utils/series";
import { getPublishedPostsSorted } from "../../utils/content/posts";
import { SITE_DESCRIPTION, formatPostDate, getPostPath } from "../../utils/posts";

const posts = await getPublishedPostsSorted();
const seriesSummary = buildSeriesSummary(posts);
---

<BaseLayout title="devjune.dev | Series" description={`시리즈별 글 목록 - ${SITE_DESCRIPTION}`}>
  <div class="library-page">
    <section class="hero library-hero">
      <p class="library-hero__eyebrow">Library</p>
      <h1>Series</h1>
      <p>Book 안에서 더 작은 흐름으로 이어지는 학습 기록과 프로젝트 개선 과정을 모았습니다.</p>
    </section>

    {
      seriesSummary.length === 0 ? (
        <p class="section-empty library-empty">아직 공개된 시리즈가 없습니다.</p>
      ) : (
        <ul class="library-series-grid">
          {seriesSummary.map((series) => {
            const previewPosts = series.posts.slice(0, 3);

            return (
              <li>
                <article class="library-series-card">
                  <div class="library-series-card__cover">
                    <span class="library-series-card__mark" aria-hidden="true">{series.title}</span>
                    <span class="library-series-card__category">{series.category}</span>
                  </div>

                  <div class="library-series-card__body">
                    <p class="library-hero__eyebrow">Series</p>
                    <h2><a href={`/series/${series.id}/`}>{series.title}</a></h2>
                    <p class="library-series-card__description">{series.description}</p>
                    <div class="library-series-card__stats">
                      <span>{series.count} posts</span>
                      <span>Updated {formatPostDate(series.latestDate)}</span>
                    </div>

                    <ol class="library-series-card__posts">
                      {previewPosts.map((post) => (
                        <li><a href={getPostPath(post)}>{post.data.title}</a></li>
                      ))}
                    </ol>

                    <div class="library-series-card__footer">
                      <span>{series.status}</span>
                      <a href={`/series/${series.id}/`}>시리즈 전체 보기</a>
                    </div>
                  </div>
                </article>
              </li>
            );
          })}
        </ul>
      )
    }
  </div>
</BaseLayout>
