---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import Pagination from "../../../components/Pagination.astro";
import { getCollection } from "astro:content";
import { POSTS_PER_PAGE, SITE_DESCRIPTION, sortPostsByDate } from "../../../utils/posts";

export async function getStaticPaths() {
  const posts = sortPostsByDate(await getCollection("blog", ({ data }) => !data.draft));

  const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
  if (totalPages <= 1) return [];

  return Array.from({ length: totalPages - 1 }, (_, index) => {
    const currentPage = index + 2;
    const start = (currentPage - 1) * POSTS_PER_PAGE;
    const end = start + POSTS_PER_PAGE;

    return {
      params: { page: String(currentPage) },
      props: {
        pagePosts: posts.slice(start, end),
        currentPage,
        totalPages,
        postCount: posts.length
      }
    };
  });
}

const { pagePosts, currentPage, totalPages, postCount } = Astro.props as {
  pagePosts: CollectionEntry<"blog">[];
  currentPage: number;
  totalPages: number;
  postCount: number;
};
---

<BaseLayout title={`devjune.dev | Blog ${currentPage}`} description={SITE_DESCRIPTION}>
  <section class="blog-list-page" aria-label={`All posts page ${currentPage}`}>
    <div class="blog-list-head">
      <div>
        <h1 class="blog-list-head__title">All Posts ({postCount})</h1>
        <p class="blog-list-head__description">{SITE_DESCRIPTION}</p>
      </div>

      <div class="view-switch" role="group" aria-label="Toggle post list view">
        <button type="button" class="view-switch__button" data-view-button="grid" aria-label="Grid view">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="4" y="4" width="6" height="6"></rect>
            <rect x="14" y="4" width="6" height="6"></rect>
            <rect x="4" y="14" width="6" height="6"></rect>
            <rect x="14" y="14" width="6" height="6"></rect>
          </svg>
        </button>
        <button type="button" class="view-switch__button" data-view-button="list" aria-label="List view">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 7h14M5 12h14M5 17h14"></path>
          </svg>
        </button>
      </div>
    </div>

    <ul class="post-list post-list--switch" data-post-list>
      {pagePosts.map((post) => (
        <li>
          <PostCard post={post} />
        </li>
      ))}
    </ul>

    <Pagination currentPage={currentPage} totalPages={totalPages} basePath="/blog" />
  </section>

  <script is:inline>
    (() => {
      const list = document.querySelector("[data-post-list]");
      const buttons = Array.from(document.querySelectorAll("[data-view-button]"));
      if (!(list instanceof HTMLElement) || buttons.length === 0) return;

      const KEY = "guseo:blog-list-view";

      const apply = (mode) => {
        const nextMode = mode === "grid" ? "grid" : "list";
        list.dataset.view = nextMode;

        for (const button of buttons) {
          if (!(button instanceof HTMLButtonElement)) continue;
          const isActive = button.dataset.viewButton === nextMode;
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-pressed", isActive ? "true" : "false");
        }
      };

      const stored = localStorage.getItem(KEY);
      apply(stored === "grid" || stored === "list" ? stored : "grid");

      for (const button of buttons) {
        if (!(button instanceof HTMLButtonElement)) continue;
        button.addEventListener("click", () => {
          const mode = button.dataset.viewButton === "grid" ? "grid" : "list";
          localStorage.setItem(KEY, mode);
          apply(mode);
        });
      }
    })();
  </script>
</BaseLayout>
