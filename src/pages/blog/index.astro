---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import PostViewSwitch from "../../components/PostViewSwitch.astro";
import Pagination from "../../components/Pagination.astro";
import { getPublishedPostsSorted } from "../../utils/content/posts";
import { getPostSlug, POSTS_PER_PAGE, SITE_DESCRIPTION } from "../../utils/posts";

const posts = await getPublishedPostsSorted();

const pagePosts = posts.slice(0, POSTS_PER_PAGE);
const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
---

<BaseLayout title="devjune.dev | Blog" description={SITE_DESCRIPTION}>
  <section
    class="blog-list-page"
    aria-label="All posts"
    data-published-post-count={posts.length}
    data-latest-post-slug={posts[0] ? getPostSlug(posts[0]) : ""}
  >
    <div class="blog-list-head">
      <div>
        <h1 class="blog-list-head__title">All Posts ({posts.length})</h1>
        <p class="blog-list-head__description">{SITE_DESCRIPTION}</p>
      </div>

      <PostViewSwitch listId="blog-post-list" storageKey="guseo:blog-list-view" />
    </div>

    <ul id="blog-post-list" class="post-list post-list--switch" data-post-list>
      {pagePosts.map((post) => (
        <li>
          <PostCard post={post} />
        </li>
      ))}
    </ul>

    <Pagination currentPage={1} totalPages={totalPages} basePath="/blog" />
  </section>
</BaseLayout>

