---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostMetaBadges from "../../components/PostMetaBadges.astro";
import { normalizeCategory } from "../../utils/categories";
import { normalizeTag } from "../../utils/tags";
import { formatPostDate, getReadingTime, sortPostsByDate } from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content, headings } = await render(post);
const allPosts = sortPostsByDate(await getCollection("blog", ({ data }) => !data.draft));
const categoryName = post.data.category?.trim() || "Uncategorized";
const categorySlug = normalizeCategory(categoryName);
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const readingTime = getReadingTime(post);
const currentIndex = allPosts.findIndex((entry) => entry.slug === post.slug);
const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : undefined;
const olderPost = currentIndex >= 0 && currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : undefined;
const postTagSet = new Set(post.data.tags.map((tag) => normalizeTag(tag)));
const relatedPosts = allPosts
  .filter((entry) => entry.slug !== post.slug)
  .map((entry) => {
    const sharedTagCount = entry.data.tags.filter((tag) => postTagSet.has(normalizeTag(tag))).length;
    const sameCategory = normalizeCategory(entry.data.category || "") === categorySlug;

    return {
      post: entry,
      score: (sameCategory ? 2 : 0) + sharedTagCount
    };
  })
  .filter((entry) => entry.score > 0)
  .sort((a, b) => b.score - a.score || b.post.data.date.valueOf() - a.post.data.date.valueOf())
  .slice(0, 3)
  .map((entry) => entry.post);
---

<BaseLayout title={`${post.data.title} | devjune.dev`} description={post.data.description} type="article">
  <div class:list={["post-view", tocHeadings.length === 0 && "post-view--single"]}>
    <article class="post">
      <header class="post__header">
        <h1>{post.data.title}</h1>
        <p class="post__description">{post.data.description}</p>

        <dl class="post-meta-grid">
          <div class="post-meta-item">
            <dt>작성일</dt>
            <dd><time datetime={post.data.date.toISOString()}>{formatPostDate(post.data.date)}</time></dd>
          </div>
          {post.data.updated && (
            <div class="post-meta-item">
              <dt>수정일</dt>
              <dd><time datetime={post.data.updated.toISOString()}>{formatPostDate(post.data.updated)}</time></dd>
            </div>
          )}
          <div class="post-meta-item">
            <dt>카테고리</dt>
            <dd><a class="tag tag--category" href={`/categories/${categorySlug}/`}>{categoryName}</a></dd>
          </div>
          <div class="post-meta-item">
            <dt>읽는 시간</dt>
            <dd>{readingTime}</dd>
          </div>
        </dl>

        <div class="post-meta-tags" aria-label="Post tags">
          {post.data.tags.map((tag) => (
            <a class="tag" href={`/tags/${normalizeTag(tag)}/`}>#{tag}</a>
          ))}
        </div>
      </header>

      <Content />

      <footer class="post-footer">
        <nav class="post-adjacent" aria-label="Previous and next posts">
          {olderPost ? (
            <a class="post-adjacent__card" href={`/blog/${olderPost.slug}/`}>
              <span>이전 글</span>
              <strong>{olderPost.data.title}</strong>
            </a>
          ) : (
            <span class="post-adjacent__card post-adjacent__card--empty">이전 글이 없습니다.</span>
          )}

          {newerPost ? (
            <a class="post-adjacent__card post-adjacent__card--next" href={`/blog/${newerPost.slug}/`}>
              <span>다음 글</span>
              <strong>{newerPost.data.title}</strong>
            </a>
          ) : (
            <span class="post-adjacent__card post-adjacent__card--empty post-adjacent__card--next">다음 글이 없습니다.</span>
          )}
        </nav>

        <section class="related-posts" aria-label="Related posts">
          <h2>Related Posts</h2>
          {relatedPosts.length > 0 ? (
            <div class="related-posts__grid">
              {relatedPosts.map((relatedPost) => (
                <article class="related-card">
                  <a class="related-card__title" href={`/blog/${relatedPost.slug}/`}>{relatedPost.data.title}</a>
                  <p>{relatedPost.data.description}</p>
                  <div class="related-card__meta">
                    <time datetime={relatedPost.data.date.toISOString()}>{formatPostDate(relatedPost.data.date)}</time>
                    <span aria-hidden="true">·</span>
                    <span>{getReadingTime(relatedPost)}</span>
                  </div>
                  <PostMetaBadges category={relatedPost.data.category} tags={relatedPost.data.tags} maxTags={2} />
                </article>
              ))}
            </div>
          ) : (
            <p class="related-posts__empty">같은 카테고리나 태그의 글이 쌓이면 이곳에 표시됩니다.</p>
          )}
        </section>
      </footer>
    </article>

    {
      tocHeadings.length > 0 && (
        <>
          <aside class="post-toc" aria-label="Document table of contents">
            <p class="post-toc__title">On This Page</p>
            <ul class="post-toc__list">
              {tocHeadings.map((heading) => (
                <li class:list={["post-toc__item", `depth-${heading.depth}`]}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
            </ul>
          </aside>

          <script is:inline>
            (() => {
              const links = Array.from(document.querySelectorAll(".post-toc__item a"));
              if (links.length === 0) return;

              const entries = links
                .map((link) => {
                  if (!(link instanceof HTMLAnchorElement)) return null;

                  const href = link.getAttribute("href") || "";
                  if (!href.startsWith("#")) return null;

                  const id = decodeURIComponent(href.slice(1));
                  const section = document.getElementById(id);
                  if (!(section instanceof HTMLElement)) return null;

                  return { link, section };
                })
                .filter((entry) => entry !== null);

              if (entries.length === 0) return;

              const applyActive = () => {
                const currentY = window.scrollY + 150;
                let active = entries[0];

                for (const entry of entries) {
                  if (entry.section.offsetTop <= currentY) {
                    active = entry;
                  } else {
                    break;
                  }
                }

                for (const entry of entries) {
                  entry.link.classList.toggle("is-active", entry === active);
                }
              };

              applyActive();
              window.addEventListener("scroll", applyActive, { passive: true });
              window.addEventListener("resize", applyActive);
            })();
          </script>
        </>
      )
    }
  </div>

  <script is:inline>
    (() => {
      const blocks = Array.from(document.querySelectorAll(".post pre"));
      if (blocks.length === 0) return;

      for (const pre of blocks) {
        if (!(pre instanceof HTMLPreElement) || pre.parentElement?.classList.contains("code-block")) continue;

        const wrapper = document.createElement("div");
        wrapper.className = "code-block";
        pre.parentNode?.insertBefore(wrapper, pre);
        wrapper.append(pre);

        const button = document.createElement("button");
        button.type = "button";
        button.className = "code-copy-button";
        button.textContent = "Copy";
        button.setAttribute("aria-label", "Copy code block");
        wrapper.append(button);

        button.addEventListener("click", async () => {
          const code = pre.querySelector("code")?.textContent ?? pre.textContent ?? "";

          try {
            await navigator.clipboard.writeText(code);
            button.textContent = "Copied";
            window.setTimeout(() => {
              button.textContent = "Copy";
            }, 1400);
          } catch {
            button.textContent = "Error";
            window.setTimeout(() => {
              button.textContent = "Copy";
            }, 1400);
          }
        });
      }
    })();
  </script>
</BaseLayout>
