---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostComments from "../../components/PostComments.astro";
import PostCodeEnhancer from "../../components/post/PostCodeEnhancer.astro";
import PostToc from "../../components/post/PostToc.astro";
import { normalizeCategory } from "../../utils/categories";
import { getAdjacentPosts, getSeriesPosts } from "../../utils/postNavigation";
import { buildPostTocHeadings } from "../../utils/postToc";
import { getSeriesContinuationMessage } from "../../utils/series";
import { formatTagName, normalizeTag } from "../../utils/tags";
import {
  DETAIL_TAG_LIMIT,
  SITE_DESCRIPTION,
  formatPostDate,
  getPostDescription,
  getReadingTime,
  sortPostsByDate
} from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content, headings } = await render(post);
const allPosts = sortPostsByDate(await getCollection("blog", ({ data }) => !data.draft));
const categoryName = post.data.category?.trim() || "Uncategorized";
const categorySlug = normalizeCategory(categoryName);
const postTitle = post.data.title.trim();
const tocHeadings = buildPostTocHeadings(headings, postTitle);
const readingTime = getReadingTime(post);
const description = getPostDescription(post);
const visibleTags = post.data.tags.slice(0, DETAIL_TAG_LIMIT);
const hiddenTagCount = Math.max(0, post.data.tags.length - visibleTags.length);
const seriesName = post.data.series?.trim();
const seriesPosts = getSeriesPosts(allPosts, seriesName);
const seriesContinuationMessage = seriesName ? getSeriesContinuationMessage(seriesName) : "";
const { newerPost, olderPost } = getAdjacentPosts(allPosts, post.id);
---

<BaseLayout
  title={`${post.data.title} | devjune.dev`}
  description={description || SITE_DESCRIPTION}
  image={post.data.heroImage}
  publishedTime={post.data.date.toISOString()}
  updatedTime={(post.data.updated ?? post.data.date).toISOString()}
  type="article"
  wideContent={true}
>
  <div class:list={["post-view", tocHeadings.length === 0 && "post-view--single"]}>
    <article class="post">
      <header class="post__header">
        <h1>{post.data.title}</h1>
        <p class="post__description">{description}</p>

        <dl class="post-meta-grid">
          <div class="post-meta-item">
            <dt>작성일</dt>
            <dd><time datetime={post.data.date.toISOString()}>{formatPostDate(post.data.date)}</time></dd>
          </div>
          {post.data.updated && (
            <div class="post-meta-item">
              <dt>수정일</dt>
              <dd><time datetime={post.data.updated.toISOString()}>{formatPostDate(post.data.updated)}</time></dd>
            </div>
          )}
          <div class="post-meta-item">
            <dt>카테고리</dt>
            <dd><a class="tag tag--category" href={`/categories/${categorySlug}/`}>{categoryName}</a></dd>
          </div>
          <div class="post-meta-item">
            <dt>읽는 시간</dt>
            <dd>{readingTime}</dd>
          </div>
        </dl>

        {
          post.data.tags.length > 0 && (
            <div class="post-meta-tags" aria-label="Post tags">
              {visibleTags.map((tag) => (
                <a class="tag" href={`/tags/${normalizeTag(tag)}/`}>#{formatTagName(tag)}</a>
              ))}
              {hiddenTagCount > 0 && <span class="tag tag--muted">+{hiddenTagCount} tags</span>}
            </div>
          )
        }
      </header>

      <Content />

      <footer class="post-footer">
        {seriesName && (
          <section class="post-series" aria-label="Post series">
            <p class="post-series__label">Series</p>
            <h2>{seriesName}</h2>
            {seriesPosts.length > 1 ? (
              <ol class="post-series__list">
                {seriesPosts.map((seriesPost) => (
                  <li class:list={[seriesPost.id === post.id && "is-current"]}>
                    {seriesPost.id === post.id ? (
                      <span>{seriesPost.data.title}</span>
                    ) : (
                      <a href={`/blog/${seriesPost.id}/`}>{seriesPost.data.title}</a>
                    )}
                  </li>
                ))}
              </ol>
            ) : (
              <p class="post-series__empty">{seriesContinuationMessage}</p>
            )}
          </section>
        )}

        <nav class="post-adjacent" aria-label="Previous and next posts">
          {olderPost ? (
            <a class="post-adjacent__card" href={`/blog/${olderPost.id}/`}>
              <span>이전 글</span>
              <strong>{olderPost.data.title}</strong>
            </a>
          ) : (
            <span class="post-adjacent__card post-adjacent__card--empty">이전 글이 없습니다.</span>
          )}

          {newerPost ? (
            <a class="post-adjacent__card post-adjacent__card--next" href={`/blog/${newerPost.id}/`}>
              <span>다음 글</span>
              <strong>{newerPost.data.title}</strong>
            </a>
          ) : (
            <span class="post-adjacent__card post-adjacent__card--empty post-adjacent__card--next">다음 글이 없습니다.</span>
          )}
        </nav>
      </footer>
    </article>

    <PostToc headings={tocHeadings} />
  </div>

  <PostComments />
  <PostCodeEnhancer />
</BaseLayout>
