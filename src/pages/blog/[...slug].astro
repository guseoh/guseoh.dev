---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryIcon from "../../components/CategoryIcon.astro";
import PostComments from "../../components/PostComments.astro";
import PostCodeEnhancer from "../../components/post/PostCodeEnhancer.astro";
import PostHeadingEnhancer from "../../components/post/PostHeadingEnhancer.astro";
import PostImageLightbox from "../../components/post/PostImageLightbox.astro";
import PostReadingProgress from "../../components/post/PostReadingProgress.astro";
import PostRelatedPosts from "../../components/post/PostRelatedPosts.astro";
import PostTableEnhancer from "../../components/post/PostTableEnhancer.astro";
import PostToc from "../../components/post/PostToc.astro";
import { normalizeCategory } from "../../utils/categories";
import { getAdjacentPosts, getSeriesPosts } from "../../utils/postNavigation";
import { buildPostTocHeadings } from "../../utils/postToc";
import { getRelatedPosts } from "../../utils/relatedPosts";
import { getSeriesContinuationMessage, getSeriesMetadata } from "../../utils/series";
import { formatTagName, normalizeTag } from "../../utils/tags";
import {
  DETAIL_TAG_LIMIT,
  GITHUB_URL,
  SITE_AUTHOR,
  SITE_DESCRIPTION,
  SITE_OG_IMAGE,
  SITE_TITLE,
  formatPostDate,
  getPostDescription,
  getPostVerificationDate,
  getReadingTime,
  isPostContentStale,
  sortPostsByDate
} from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content, headings } = await render(post);
const allPosts = sortPostsByDate(await getCollection("blog", ({ data }) => !data.draft));
const categoryName = post.data.category?.trim() || "Uncategorized";
const categorySlug = normalizeCategory(categoryName);
const postTitle = post.data.title.trim();
const tocHeadings = buildPostTocHeadings(headings, postTitle);
const readingTime = getReadingTime(post);
const description = getPostDescription(post);
const visibleTags = post.data.tags.slice(0, DETAIL_TAG_LIMIT);
const hiddenTagCount = Math.max(0, post.data.tags.length - visibleTags.length);
const seriesName = post.data.series?.trim();
const seriesMetadata = seriesName ? getSeriesMetadata(seriesName) : undefined;
const seriesTitle = seriesMetadata?.title ?? seriesName;
const seriesPosts = getSeriesPosts(allPosts, seriesName);
const seriesContinuationMessage = seriesName ? getSeriesContinuationMessage(seriesName) : "";
const { newerPost, olderPost } = getAdjacentPosts(allPosts, post.id);
const relatedPosts = getRelatedPosts(post, allPosts, { limit: 3 });
const siteUrl = Astro.site ?? new URL("https://guseoh.github.io");
const postUrl = new URL(Astro.url.pathname, siteUrl).toString();
const postImage = new URL(post.data.heroImage ?? SITE_OG_IMAGE, siteUrl).toString();
const verificationDate = getPostVerificationDate(post);
const isStalePost = isPostContentStale(post);
const postStructuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description,
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updated ?? post.data.date).toISOString(),
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl
  },
  url: postUrl,
  author: {
    "@type": "Person",
    name: SITE_AUTHOR,
    url: GITHUB_URL
  },
  publisher: {
    "@type": "Organization",
    name: SITE_TITLE
  },
  image: postImage,
  articleSection: categoryName,
  keywords: post.data.tags.length > 0 ? post.data.tags : undefined
};
---

<BaseLayout
  title={`${post.data.title} | devjune.dev`}
  description={description || SITE_DESCRIPTION}
  image={post.data.heroImage}
  publishedTime={post.data.date.toISOString()}
  updatedTime={(post.data.updated ?? post.data.date).toISOString()}
  type="article"
  wideContent={true}
  structuredData={postStructuredData}
  currentCategory={post.data.category}
>
  <PostReadingProgress postId={post.id} />

  <div class:list={["post-view", tocHeadings.length === 0 && "post-view--single"]}>
    <PostToc headings={tocHeadings} />

    <article class="post">
      <header class="post__header">
        <h1>{post.data.title}</h1>
        <p class="post__description">{description}</p>

        <dl class="post-meta-grid">
          <div class="post-meta-item">
            <dt>작성일</dt>
            <dd><time datetime={post.data.date.toISOString()}>{formatPostDate(post.data.date)}</time></dd>
          </div>
          {post.data.updated && (
            <div class="post-meta-item">
              <dt>수정일</dt>
              <dd><time datetime={post.data.updated.toISOString()}>{formatPostDate(post.data.updated)}</time></dd>
            </div>
          )}
          {post.data.lastVerified && (
            <div class="post-meta-item">
              <dt>마지막 검증</dt>
              <dd><time datetime={post.data.lastVerified.toISOString()}>{formatPostDate(post.data.lastVerified)}</time></dd>
            </div>
          )}
          <div class="post-meta-item">
            <dt>카테고리</dt>
            <dd>
              <a class="tag tag--category" href={`/categories/${categorySlug}/`}>
                <CategoryIcon category={categoryName} />
                <span>{categoryName}</span>
              </a>
            </dd>
          </div>
          <div class="post-meta-item">
            <dt>읽는 시간</dt>
            <dd>{readingTime}</dd>
          </div>
        </dl>

        {
          post.data.tags.length > 0 && (
            <div class="post-meta-tags" aria-label="Post tags">
              {visibleTags.map((tag) => (
                <a class="tag" href={`/tags/${normalizeTag(tag)}/`}>#{formatTagName(tag)}</a>
              ))}
              {hiddenTagCount > 0 && <span class="tag tag--muted">+{hiddenTagCount} tags</span>}
            </div>
          )
        }
      </header>

      {isStalePost && (
        <aside class="post-freshness-note" aria-label="게시글 검증 안내">
          <strong>검증 안내</strong>
          <p>
            이 글은 마지막 검증 후 1년 이상 지났습니다. 일부 내용이 현재 버전과 다를 수 있습니다.
            <span> 마지막 기준일: <time datetime={verificationDate.toISOString()}>{formatPostDate(verificationDate)}</time></span>
          </p>
        </aside>
      )}

      <div class="post__content">
        <Content />
      </div>

      <footer class="post-footer">
        {seriesName && seriesTitle && (
          <section class="post-series" aria-label="Post series">
            <p class="post-series__label">Series</p>
            <h2>
              {seriesMetadata ? <a href={`/series/${seriesMetadata.id}/`}>{seriesTitle}</a> : seriesTitle}
            </h2>
            {seriesPosts.length > 1 ? (
              <ol class="post-series__list">
                {seriesPosts.map((seriesPost) => (
                  <li class:list={[seriesPost.id === post.id && "is-current"]}>
                    {seriesPost.id === post.id ? (
                      <span>{seriesPost.data.title}</span>
                    ) : (
                      <a href={`/blog/${seriesPost.id}/`}>{seriesPost.data.title}</a>
                    )}
                  </li>
                ))}
              </ol>
            ) : (
              <p class="post-series__empty">{seriesContinuationMessage}</p>
            )}
          </section>
        )}

        <PostRelatedPosts relatedPosts={relatedPosts} />

        <nav class="post-adjacent" aria-label="Previous and next posts">
          {olderPost ? (
            <a class="post-adjacent__card" href={`/blog/${olderPost.id}/`}>
              <span>이전 글</span>
              <strong>{olderPost.data.title}</strong>
            </a>
          ) : (
            <span class="post-adjacent__card post-adjacent__card--empty">이전 글이 없습니다.</span>
          )}

          {newerPost ? (
            <a class="post-adjacent__card post-adjacent__card--next" href={`/blog/${newerPost.id}/`}>
              <span>다음 글</span>
              <strong>{newerPost.data.title}</strong>
            </a>
          ) : (
            <span class="post-adjacent__card post-adjacent__card--empty post-adjacent__card--next">다음 글이 없습니다.</span>
          )}
        </nav>
      </footer>
    </article>
  </div>

  <PostComments />
  <PostImageLightbox />
  <PostHeadingEnhancer />
  <PostTableEnhancer />
  <PostCodeEnhancer />
</BaseLayout>
