---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBookSummaries, type BookSummary } from "../../utils/books";
import { getCategoryName, normalizeCategory } from "../../utils/categories";
import { formatPostDate, getPostDescription, SITE_DESCRIPTION, sortPostsByDate } from "../../utils/posts";

export async function getStaticPaths() {
  const posts = sortPostsByDate(await getCollection("blog", ({ data }) => !data.draft));

  return buildBookSummaries(posts).map((book) => ({
    params: { book: book.id },
    props: { book }
  }));
}

const { book } = Astro.props as { book: BookSummary };

function getActivityDate(post: CollectionEntry<"blog">) {
  return post.data.updated ?? post.data.date;
}
---

<BaseLayout title={`devjune.dev | ${book.title}`} description={`${book.description} - ${SITE_DESCRIPTION}`}>
  <div class="library-page">
    <section class="book-detail-hero">
      <div class:list={["book-detail-hero__cover", `book-card--${book.tone}`]} aria-hidden="true">
        <span>devjune.dev</span>
        <strong>{book.coverLabel}</strong>
        <i></i>
      </div>

      <div class="book-detail-hero__content">
        <p class="library-hero__eyebrow">Book</p>
        <h1>{book.title}</h1>
        <p>{book.description}</p>
        <dl class="library-summary">
          <div>
            <dt>Chapters</dt>
            <dd>{book.count}</dd>
          </div>
          <div>
            <dt>Updated</dt>
            <dd>{formatPostDate(book.latestDate)}</dd>
          </div>
        </dl>
        <div class="library-topic-list" aria-label="Book categories">
          {book.categories.map((category) => (
            <a href={`/categories/${normalizeCategory(category)}/`}>{category}</a>
          ))}
        </div>
      </div>
    </section>

    <section class="chapter-section" aria-labelledby="book-chapters-title">
      <div class="chapter-section__head">
        <div>
          <p class="library-hero__eyebrow">Contents</p>
          <h2 id="book-chapters-title">Chapters</h2>
        </div>
        <span>{book.count}개의 글</span>
      </div>

      <ol class="chapter-list">
        {book.posts.map((post, index) => (
          <li>
            <a href={`/blog/${post.id}/`}>
              <span class="chapter-list__number">
                {String(post.data.chapter ?? index + 1).padStart(2, "0")}
              </span>
              <span class="chapter-list__content">
                <strong>{post.data.title}</strong>
                <span>{getPostDescription(post)}</span>
              </span>
              <span class="chapter-list__meta">
                <span>{getCategoryName(post)}</span>
                <time datetime={getActivityDate(post).toISOString()}>{formatPostDate(getActivityDate(post))}</time>
              </span>
            </a>
          </li>
        ))}
      </ol>
    </section>
  </div>
</BaseLayout>
