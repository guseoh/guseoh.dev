---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBookSummaries } from "../../utils/books";
import { formatPostDate, SITE_DESCRIPTION, sortPostsByDate } from "../../utils/posts";

const posts = sortPostsByDate(await getCollection("blog", ({ data }) => !data.draft));
const books = buildBookSummaries(posts);
---

<BaseLayout title="devjune.dev | Books" description={`주제별 학습 기록을 책처럼 묶어둔 공간 - ${SITE_DESCRIPTION}`}>
  <div class="library-page">
    <section class="hero library-hero">
      <p class="library-hero__eyebrow">Library</p>
      <h1>Books</h1>
      <p>큰 학습 주제를 한 권의 책처럼 묶고, 게시글을 chapter 순서로 탐색할 수 있도록 정리했습니다.</p>
    </section>

    {
      books.length === 0 ? (
        <p class="section-empty library-empty">아직 공개된 Book이 없습니다.</p>
      ) : (
        <ul class="book-grid">
          {books.map((book) => (
            <li>
              <a class:list={["book-card", `book-card--${book.tone}`]} href={`/books/${book.id}/`}>
                <span class="book-card__cover" aria-hidden="true">
                  <span class="book-card__cover-kicker">devjune.dev</span>
                  <strong>{book.coverLabel}</strong>
                  <span class="book-card__cover-rule"></span>
                </span>

                <span class="book-card__body">
                  <span class="book-card__topics">{book.topics.join(" · ")}</span>
                  <strong class="book-card__title">{book.title}</strong>
                  <span class="book-card__description">{book.description}</span>
                  <span class="book-card__meta">
                    <span>{book.count} {book.count === 1 ? "chapter" : "chapters"}</span>
                    <span>Updated {formatPostDate(book.latestDate)}</span>
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>
