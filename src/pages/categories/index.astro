---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import CategoryMenu from "../../components/CategoryMenu.astro";
import { buildCategoryHierarchy } from "../../utils/categories";
import { SITE_DESCRIPTION } from "../../utils/posts";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const categoryHierarchy = buildCategoryHierarchy(posts);
---

<BaseLayout title="devjune.dev | Categories" description={SITE_DESCRIPTION}>
  <section class="hero">
    <h1>Categories</h1>
    <p>Project, Spring, JPA, Database, DevOps, Git 중심으로 학습/개선 기록을 묶어둔 공간입니다.</p>
  </section>

  <CategoryMenu groups={categoryHierarchy} idPrefix="categories-page" variant="page" label="Category index menu" />
</BaseLayout>

