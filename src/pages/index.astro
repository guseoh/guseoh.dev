---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../config/site";
import { getPublishedPostsSorted } from "../utils/content/posts";
import { SITE_DESCRIPTION, SITE_TITLE } from "../utils/posts";
import ActivitySection from "../components/home/ActivitySection.astro";
import ArchiveHero from "../components/home/ArchiveHero.astro";
import LatestPosts from "../components/home/LatestPosts.astro";

const posts = await getPublishedPostsSorted();
---

<BaseLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  minimalHome={true}
>
  <ArchiveHero />
  <ActivitySection posts={posts} username={SITE.githubActivityUsername} />
  <LatestPosts posts={posts} />
</BaseLayout>

