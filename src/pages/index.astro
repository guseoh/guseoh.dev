---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_DESCRIPTION, SITE_TITLE, sortPostsByDate } from "../utils/posts";
import ArchiveHero from "../components/home/ArchiveHero.astro";
import LatestPosts from "../components/home/LatestPosts.astro";

const posts = sortPostsByDate(await getCollection("blog", ({ data }) => !data.draft));
---

<BaseLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  minimalHome={true}
>
  <ArchiveHero />
  <LatestPosts posts={posts} />
</BaseLayout>

